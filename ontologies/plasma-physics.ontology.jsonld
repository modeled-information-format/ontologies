        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "instability_type": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/laser-plasma-interaction",
      "@type": "mif:EntityType",
      "name": "laser-plasma-interaction",
      "base": "semantic",
      "description": "Laser-plasma interactions",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
