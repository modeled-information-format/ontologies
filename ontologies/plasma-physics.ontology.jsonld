            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-interaction-nonlaser",
      "@type": "mif:EntityType",
      "name": "plasma-interaction-nonlaser",
      "base": "semantic",
      "description": "Plasma interactions (nonlaser)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
