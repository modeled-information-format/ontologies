    {
      "@id": "mif:entityType/plasma-heating-method",
      "@type": "mif:EntityType",
      "name": "plasma-heating-method",
      "base": "procedural",
      "description": "Plasma production and heating",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "heating_mechanism": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/magnetic-confinement-configuration",
      "@type": "mif:EntityType",
      "name": "magnetic-confinement-configuration",
      "base": "semantic",
      "description": "Magnetic confinement and equilibrium device configuration (tokamaks, stellarators, reversed-field pinches, heliacs)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "configuration_type": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Renamed from device_name to match research.ontology.yaml's apparatus field name directly"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/laser-inertial-confinement-device",
      "@type": "mif:EntityType",
      "name": "laser-inertial-confinement-device",
      "base": "semantic",
      "description": "Laser inertial confinement fusion device",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Renamed from device_name to match research.ontology.yaml's apparatus field name directly"
          },
          "laser_power": {
            "type": "number"
          },
          "target_type": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/pinch-device",
      "@type": "mif:EntityType",
      "name": "pinch-device",
      "base": "semantic",
      "description": "Pinch devices (incl. Z-pinches)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "pinch_type": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "The device's own name (e.g. a specific Z-pinch facility name), distinct from pinch_type (the pinch mechanism category); no prior equivalent field existed"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/intense-particle-beam-source",
      "@type": "mif:EntityType",
      "name": "intense-particle-beam-source",
      "base": "semantic",
      "description": "Intense particle beams and radiation sources",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "beam_type": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "description": "The PACS section's own heading text, distinct from beam_type (a further sub-classification of the beam kind); no prior equivalent field existed"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-simulation-method",
      "@type": "mif:EntityType",
      "name": "plasma-simulation-method",
      "base": "procedural",
      "description": "Plasma simulation methods (incl. perturbative methods)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/research-procedure"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Renamed from simulation_method to match research-procedure's field name directly"
          },
          "code_name": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-diagnostic-technique",
      "@type": "mif:EntityType",
      "name": "plasma-diagnostic-technique",
      "base": "procedural",
      "description": "Plasma diagnostic techniques and instrumentation",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/research-procedure"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Renamed from technique_name to match research-procedure's field name directly"
          },
          "measured_quantity": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-device",
      "@type": "mif:EntityType",
      "name": "plasma-device",
      "base": "semantic",
      "description": "Plasma devices",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "name"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Renamed from device_name to match research.ontology.yaml's apparatus field name directly"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-application",
      "@type": "mif:EntityType",
      "name": "plasma-application",
      "base": "semantic",
      "description": "Plasma applications",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "application_domain": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "description": "The PACS section's own heading text, distinct from application_domain (the specific application area); no prior equivalent field existed"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/electric-discharge",
      "@type": "mif:EntityType",
      "name": "electric-discharge",
      "base": "semantic",
      "description": "Electric discharges",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "discharge_type": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "description": "The PACS section's own heading text, distinct from discharge_type (the specific discharge mechanism); no prior equivalent field existed"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/plasma-parameter",
      "@type": "mif:EntityType",
      "name": "plasma-parameter",
      "base": "semantic",
      "description": "A fundamental named plasma physical quantity (Debye length, plasma frequency, Larmor radius)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/physical-quantity"
      ],
      "schema": {
        "required": [
          "value",
          "variable"
        ],
        "properties": {
          "variable": {
            "type": "string",
            "description": "Renamed from parameter_name to match physical-science-base's physical-quantity field name directly"
          },
          "symbol": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          }
        }
      }
    }
  ],
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(plasma instability|plasma wave|Langmuir wave|Alfven wave)\\b",
        "suggest_entity": "mif:entityType/plasma-wave-instability",
        "suggest_namespace": "_semantic/plasma-phenomena"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(tokamak|stellarator|magnetic confinement|reversed-field pinch)\\b",
        "suggest_entity": "mif:entityType/magnetic-confinement-configuration",
        "suggest_namespace": "_semantic/plasma-devices"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(inertial confinement fusion|ICF|laser-driven fusion)\\b",
        "suggest_entity": "mif:entityType/laser-inertial-confinement-device",
        "suggest_namespace": "_semantic/plasma-devices"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Debye length|plasma frequency|Larmor radius)\\b",
        "suggest_entity": "mif:entityType/plasma-parameter",
        "suggest_namespace": "_semantic/plasma-parameters"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Langmuir probe|plasma diagnostic|Thomson scattering)\\b",
        "suggest_entity": "mif:entityType/plasma-diagnostic-technique",
        "suggest_namespace": "_procedural/plasma-diagnostics"
      }
    ]
  }
}