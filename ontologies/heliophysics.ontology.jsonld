{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://github.com/zircote/MIF/ontology#",
    "mif": "https://github.com/zircote/MIF#",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/heliophysics",
  "@type": "mif:Ontology",
  "identifier": "heliophysics",
  "version": "0.1.0",
  "description": "Heliophysics domain ontology: space-weather phenomena (geomagnetic storms, solar flares, coronal mass ejections), their named indices and grid impacts, auroral observations, NOAA severity-scale alerts, and monitoring platforms",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "heliophysics-phenomena": {
          "@id": "mif:namespace/semantic/heliophysics-phenomena",
          "@type": "mif:Namespace",
          "name": "heliophysics-phenomena",
          "description": "Heliophysical/solar-terrestrial phenomenon classification (PACS 91.25, 96.50, 96.60)",
          "type_hint": "semantic"
        },
        "heliophysics-quantities": {
          "@id": "mif:namespace/semantic/heliophysics-quantities",
          "@type": "mif:Namespace",
          "name": "heliophysics-quantities",
          "description": "Named heliophysics/space-weather physical quantities",
          "type_hint": "semantic"
        },
        "heliophysics-observations": {
          "@id": "mif:namespace/semantic/heliophysics-observations",
          "@type": "mif:Namespace",
          "name": "heliophysics-observations",
          "description": "Observed or forecast heliophysics data (e.g. aurora sightings)",
          "type_hint": "semantic"
        },
        "heliophysics-alerts": {
          "@id": "mif:namespace/semantic/heliophysics-alerts",
          "@type": "mif:Namespace",
          "name": "heliophysics-alerts",
          "description": "NOAA space-weather severity-scale alert levels",
          "type_hint": "semantic"
        },
        "heliophysics-devices": {
          "@id": "mif:namespace/semantic/heliophysics-devices",
          "@type": "mif:Namespace",
          "name": "heliophysics-devices",
          "description": "Space-weather monitoring platforms and instruments",
          "type_hint": "semantic"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/geomagnetic-storm",
      "@type": "mif:EntityType",
      "name": "geomagnetic-storm",
      "base": "semantic",
      "description": "Geomagnetism and paleomagnetism; geoelectricity \u2014 classification of geomagnetic field disturbances (storms, substorms) driven by solar-wind coupling",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "storm_phase": {
            "type": "string",
            "description": "e.g. initial, main, recovery phase of the storm"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/solar-flare-activity",
      "@type": "mif:EntityType",
      "name": "solar-flare-activity",
      "base": "semantic",
      "description": "Solar activity \u2014 flares and active-region phenomena on the solar disk",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/coronal-mass-ejection",
      "@type": "mif:EntityType",
      "name": "coronal-mass-ejection",
      "base": "semantic",
      "description": "Coronal mass ejections and solar-wind particle-emission events",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/solar-terrestrial-coupling",
      "@type": "mif:EntityType",
      "name": "solar-terrestrial-coupling",
      "base": "semantic",
      "description": "Interplanetary physics \u2014 solar-wind propagation and solar-wind/magnetosphere/ionosphere coupling",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/classification-scheme-entry"
      ],
      "schema": {
        "required": [
          "pacs_code",
          "title"
        ],
        "properties": {
          "pacs_code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/geomagnetic-index",
      "@type": "mif:EntityType",
      "name": "geomagnetic-index",
      "base": "semantic",
      "description": "A named geomagnetic activity index value (e.g. Kp, ap, Ap, Dst) measuring global or storm-time geomagnetic disturbance",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/physical-quantity"
      ],
      "schema": {
        "required": [
          "value",
          "variable"
        ],
        "properties": {
          "variable": {
            "type": "string",
            "description": "Matches physical-science-base's physical-quantity field name directly (e.g. 'Kp index', 'Dst index')"
          },
          "symbol": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "index_family": {
            "type": "string",
            "enum": [
              "Kp",
              "ap",
              "Ap",
              "Dst",
              "Cp",
              "C9"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/solar-flare-flux",
      "@type": "mif:EntityType",
      "name": "solar-flare-flux",
      "base": "semantic",
      "description": "GOES X-ray flux measurement mapped to the A/B/C/M/X solar-flare class",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/physical-quantity"
      ],
      "schema": {
        "required": [
          "value",
          "variable"
        ],
        "properties": {
          "variable": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "flare_class": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "M",
              "X"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/geomagnetically-induced-current",
      "@type": "mif:EntityType",
      "name": "geomagnetically-induced-current",
      "base": "semantic",
      "description": "A geomagnetically induced current (GIC) measured in power-grid transformers or pipelines during a geomagnetic disturbance",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/physical-quantity"
      ],
      "schema": {
        "required": [
          "value",
          "variable"
        ],
        "properties": {
          "variable": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "asset_type": {
            "type": "string",
            "description": "The grid asset the current was measured in, e.g. transformer neutral, pipeline"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/aurora-observation",
      "@type": "mif:EntityType",
      "name": "aurora-observation",
      "base": "semantic",
      "description": "A reported or forecast auroral-display sighting",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/observation"
      ],
      "schema": {
        "required": [
          "value",
          "variable"
        ],
        "properties": {
          "variable": {
            "type": "string",
            "description": "e.g. 'aurora visibility'"
          },
          "value": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "visibility_forecast_model": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "reported_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/space-weather-alert-level",
      "@type": "mif:EntityType",
      "name": "space-weather-alert-level",
      "base": "semantic",
      "description": "A NOAA Space Weather Prediction Center severity-scale level (G geomagnetic storm, S solar radiation storm, R radio blackout), analogous to hurricane/earthquake severity scales",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/scored",
        "mif:trait/categorized"
      ],
      "schema": {
        "required": [
          "scale",
          "level"
        ],
        "properties": {
          "scale": {
            "type": "string",
            "enum": [
              "G",
              "S",
              "R"
            ]
          },
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "event_name": {
            "type": "string"
          },
          "issued_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/space-weather-observatory",
      "@type": "mif:EntityType",
      "name": "space-weather-observatory",
      "base": "semantic",
      "description": "A space-weather monitoring platform or instrument (satellite or ground magnetometer)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Matches research.ontology.yaml's apparatus field name directly"
          },
          "platform_type": {
            "type": "string",
            "enum": [
              "satellite",
              "ground-magnetometer",
              "network"
            ]
          },
          "operator": {
            "type": "string"
          },
          "orbit_or_location": {
            "type": "string"
          }
        }
      }
    }
  ],
  "relationships": {
    "triggers": {
      "@id": "mif:relationship/triggers",
      "@type": "mif:Relationship",
      "name": "triggers",
      "description": "A solar/heliophysical event triggers a downstream geomagnetic or grid effect",
      "from": [
        "mif:entityType/coronal-mass-ejection",
        "mif:entityType/solar-flare-activity"
      ],
      "to": [
        "mif:entityType/geomagnetic-storm",
        "mif:entityType/geomagnetically-induced-current"
      ],
      "symmetric": false
    },
    "measured_by": {
      "@id": "mif:relationship/measured_by",
      "@type": "mif:Relationship",
      "name": "measured_by",
      "description": "A heliophysics quantity or observation is measured by a space-weather observatory",
      "from": [
        "mif:entityType/geomagnetic-index",
        "mif:entityType/solar-flare-flux",
        "mif:entityType/aurora-observation"
      ],
      "to": [
        "mif:entityType/space-weather-observatory"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(geomagnetic storm|magnetic storm|substorm)\\b",
        "suggest_entity": "mif:entityType/geomagnetic-storm",
        "suggest_namespace": "_semantic/heliophysics-phenomena"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(solar flare|X-class flare|M-class flare|active region)\\b",
        "suggest_entity": "mif:entityType/solar-flare-activity",
        "suggest_namespace": "_semantic/heliophysics-phenomena"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(coronal mass ejection|CME|halo CME)\\b",
        "suggest_entity": "mif:entityType/coronal-mass-ejection",
        "suggest_namespace": "_semantic/heliophysics-phenomena"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(solar wind|interplanetary magnetic field|IMF)\\b",
        "suggest_entity": "mif:entityType/solar-terrestrial-coupling",
        "suggest_namespace": "_semantic/heliophysics-phenomena"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Kp index|Dst index|planetary K index|Ap index)\\b",
        "suggest_entity": "mif:entityType/geomagnetic-index",
        "suggest_namespace": "_semantic/heliophysics-quantities"
      },
      {
        "@id": "mif:pattern/5",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(GOES X-ray flux|flare classification|X-ray flare class)\\b",
        "suggest_entity": "mif:entityType/solar-flare-flux",
        "suggest_namespace": "_semantic/heliophysics-quantities"
      },
      {
        "@id": "mif:pattern/6",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(geomagnetically induced current|\\bGIC\\b)\\b",
        "suggest_entity": "mif:entityType/geomagnetically-induced-current",
        "suggest_namespace": "_semantic/heliophysics-quantities"
      },
      {
        "@id": "mif:pattern/7",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(aurora|auroral display|northern lights|southern lights)\\b",
        "suggest_entity": "mif:entityType/aurora-observation",
        "suggest_namespace": "_semantic/heliophysics-observations"
      },
      {
        "@id": "mif:pattern/8",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(NOAA space weather scale|G[1-5] geomagnetic storm|S[1-5] radiation storm|R[1-5] radio blackout)\\b",
        "suggest_entity": "mif:entityType/space-weather-alert-level",
        "suggest_namespace": "_semantic/heliophysics-alerts"
      },
      {
        "@id": "mif:pattern/9",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(GOES satellite|DSCOVR|ACE spacecraft|INTERMAGNET|magnetometer network)\\b",
        "suggest_entity": "mif:entityType/space-weather-observatory",
        "suggest_namespace": "_semantic/heliophysics-devices"
      }
    ]
  }
}