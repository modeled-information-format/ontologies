{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "aliases": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "exemplars": {
      "@id": "skos:example",
      "@container": "@set"
    },
    "negative_examples": {
      "@id": "https://mif-spec.dev/ns/ontology#negativeExample",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/market-research",
  "@type": "mif:Ontology",
  "identifier": "market-research",
  "version": "0.4.0",
  "description": "Market-research domain ontology \u2014 segments, competitors, sizing, demand, intelligence",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "market": {
          "@id": "mif:namespace/semantic/market",
          "@type": "mif:Namespace",
          "name": "market",
          "description": "Segments, competitors, brands, personas, sizing, forces, demand, data sources",
          "type_hint": "semantic"
        },
        "reports": {
          "@id": "mif:namespace/semantic/reports",
          "@type": "mif:Namespace",
          "name": "reports",
          "description": "Market-intelligence reports and analyses",
          "type_hint": "semantic"
        }
      }
    },
    "procedural": {
      "@id": "mif:namespace/procedural",
      "@type": "mif:Namespace",
      "name": "procedural",
      "children": {
        "research": {
          "@id": "mif:namespace/procedural/research",
          "@type": "mif:Namespace",
          "name": "research",
          "description": "Survey instruments and research plan specifications",
          "type_hint": "procedural"
        }
      }
    },
    "episodic": {
      "@id": "mif:namespace/episodic",
      "@type": "mif:Namespace",
      "name": "episodic",
      "children": {
        "research": {
          "@id": "mif:namespace/episodic/research",
          "@type": "mif:Namespace",
          "name": "research",
          "description": "Win-loss analyses and research episodes",
          "type_hint": "episodic"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/segment",
      "@type": "mif:EntityType",
      "name": "segment",
      "base": "semantic",
      "description": "A market segment \u2014 a defined slice of a market",
      "aliases": [
        "market segment",
        "buyer segment",
        "customer segment",
        "target segment"
      ],
      "exemplars": [
        "A structured knowledge infrastructure product maps to several distinct buyer segments, each with its own pain point and willingness to pay",
        "Enterprise buyers have shifted decisively toward buying commercial software-as-a-service rather than building it in-house"
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "geographic_area": {
            "type": "string"
          },
          "audience_type": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/competitor",
      "@type": "mif:EntityType",
      "name": "competitor",
      "base": "semantic",
      "description": "A competing organization in a market (EXTENDS schema:Organization)",
      "negative_examples": [
        "Individual vendors like CrowdStrike and Salesforce compete aggressively by undercutting on price, expanding feature sets faster than rivals, and differentiating on analyst rankings, collectively driving up the competitive intensity in the endpoint-security and CRM markets."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "legal_name"
        ],
        "properties": {
          "legal_name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "area_served": {
            "type": "string"
          },
          "number_of_employees": {
            "type": "integer"
          },
          "founding_date": {
            "type": "string",
            "format": "date"
          },
          "makes_offer": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/brand",
      "@type": "mif:EntityType",
      "name": "brand",
      "base": "semantic",
      "description": "A brand maintained by a competitor (REUSES schema:Brand)",
      "negative_examples": [
        "New DTC skincare brands can enter the market at low cost via white-label manufacturing and Shopify platforms, allowing fresh entrants to compete for social-media discovery and rapidly gain mindshare among Gen Z consumers.",
        "Salesforce and Shopify are recognized enterprise software brands that customers actively choose and switch between based on feature fit and vendor reputation in the platform-software market.",
        "Demand for 'clean-label' skincare products, marketed around ingredient transparency and the exclusion of specific chemical categories, has grown among Gen Z and Millennial consumers, who report checking ingredient lists via apps like INCIDecoder or Yuka before purchase, a behavior historically far less common among older cohorts. That demand shift has pressured legacy skincare brands to reformulate or launch clean-label sub-brands rather than continuing to compete on efficacy claims alone."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "logo": {
            "type": "string",
            "format": "uri"
          },
          "slogan": {
            "type": "string"
          },
          "aggregate_rating": {
            "type": "string"
          },
          "review": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/buyer-persona",
      "@type": "mif:EntityType",
      "name": "buyer-persona",
      "base": "semantic",
      "description": "A target buyer audience or ideal-customer profile (REUSES schema:Audience)",
      "negative_examples": [
        "This segment covers consumers aged roughly 13 to 26 who discover and purchase skincare primarily through short-form video, TikTok, Instagram Reels, rather than in-store browsing or search-driven discovery, and who weight ingredient transparency and influencer or creator endorsement heavily in their purchase decisions. Purchase frequency skews toward smaller, more frequent basket sizes than older cohorts, and brand loyalty runs comparatively low, with switching typically driven by whatever product is currently trending.",
        "LinkedIn is a professional-networking brand that Microsoft Corporation acquired in 2016 and has since operated as a standalone brand and business segment, reported separately in Microsoft's financial disclosures rather than folded into the broader Microsoft 365 brand. Its Sales Navigator and Talent Solutions products are commonly cited in B2B market research as a data source for firmographic and buyer-persona targeting, given the depth of professional-profile data the platform holds.",
        "This respondent cohort was screened to require current involvement in software-purchasing decisions at organizations with 1,000 or more employees and at least a director-level title, yielding 412 qualified respondents for a brand-awareness and vendor-consideration study. The screening explicitly excluded respondents whose involvement was limited to using already-purchased software without any purchasing influence, so the sample wouldn't be diluted with end-user-only perspectives.",
        "This service offering delivers a recurring, personalized selection of skincare products on a monthly or bi-monthly cadence, based on a customer's stated skin type and concerns collected at signup, positioned against one-time retail purchase by offering product discovery and a mild price discount relative to buying full-size items individually. Churn management typically relies on a pause-rather-than-cancel default and periodic re-personalization surveys to keep box contents relevant as customer preferences shift over time.",
        "This win-loss analysis covers a set of retail-buyer decisions on shelf placement for a DTC skincare brand seeking its first major retail-channel expansion, based on interviews with retail category buyers who declined or accepted the brand's pitch. The recurring theme identified among declined pitches was insufficient existing DTC repeat-purchase data: category buyers repeatedly cited an inability to independently verify the brand's claimed online repeat-purchase rate as the deciding factor, since retail buyers use DTC retention metrics as a proxy for in-store sell-through risk before committing shelf space."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "audience_type"
        ],
        "properties": {
          "audience_type": {
            "type": "string"
          },
          "geographic_area": {
            "type": "string"
          },
          "required_gender": {
            "type": "string"
          },
          "required_min_age": {
            "type": "integer"
          },
          "required_max_age": {
            "type": "integer"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/respondent-segment",
      "@type": "mif:EntityType",
      "name": "respondent-segment",
      "base": "semantic",
      "description": "A survey-respondent cohort defined by screening criteria",
      "negative_examples": [
        "Demand for F2P games skews heavily toward older-demographics segments aged 40+ who prefer puzzle and strategy mechanics, representing a growing revenue opportunity for mobile developers."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "audience_type": {
            "type": "string"
          },
          "geographic_area": {
            "type": "string"
          },
          "required_min_age": {
            "type": "integer"
          },
          "required_max_age": {
            "type": "integer"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/sizing-estimate",
      "@type": "mif:EntityType",
      "name": "sizing-estimate",
      "base": "semantic",
      "description": "A market-sizing estimate (TAM/SAM/SOM)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "estimated_value": {
            "type": "string"
          },
          "valid_through": {
            "type": "string",
            "format": "date"
          },
          "eligible_region": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/competitive-force",
      "@type": "mif:EntityType",
      "name": "competitive-force",
      "base": "semantic",
      "description": "A Porter competitive force shaping competitive intensity",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "force_type",
          "industry_scope"
        ],
        "properties": {
          "force_type": {
            "type": "string",
            "enum": [
              "new-entrants",
              "buyer-power",
              "supplier-power",
              "substitutes",
              "competitive-rivalry"
            ]
          },
          "intensity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low",
              "indeterminate"
            ]
          },
          "industry_scope": {
            "type": "string"
          },
          "key_drivers": {
            "type": "string"
          },
          "trend_direction": {
            "type": "string",
            "enum": [
              "increasing",
              "stable",
              "decreasing"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/service-offering",
      "@type": "mif:EntityType",
      "name": "service-offering",
      "base": "semantic",
      "description": "A service offering provided into a market (EXTENDS schema:Service)",
      "negative_examples": [
        "Demand for embedded-payment capabilities is driving vendors to offer recurring-revenue models like subscription-box curation, where payment processing becomes a value-add feature bundled with the core product experience.",
        "New observability vendors are offering cloud-native monitoring and AI-driven root-cause-analysis services that compete with legacy enterprise monitoring platforms, changing how operations teams approach infrastructure visibility.",
        "Stripe, Inc. is a privately held payment-processing and financial-infrastructure vendor headquartered in South San Francisco, offering an API-first platform for online payments, billing, and embedded finance, Stripe Treasury, Stripe Capital, aimed primarily at software developers and vertical SaaS companies embedding payments into their own products. It competes with both legacy payment processors and other developer-first platforms such as Adyen and Braintree, and as of this writing remains venture-backed rather than publicly traded.",
        "CB Insights' embedded-fintech intelligence service provides analysis and tracking of fintech-in-enterprise offerings, helping investors and operators understand the strategic implications of fintech integrations."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          },
          "brand": {
            "type": "string"
          },
          "area_served": {
            "type": "string"
          },
          "service_type": {
            "type": "string"
          },
          "offers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/market-demand",
      "@type": "mif:EntityType",
      "name": "market-demand",
      "base": "semantic",
      "description": "Market demand for an offered item (REUSES schema:Demand)",
      "negative_examples": [
        "Buyers with negotiating power in CRM and enterprise software markets demand better pricing, lower switching costs, and extended payment terms, forcing vendors to improve commercial flexibility to maintain customer retention and market share.",
        "Conjoint-analysis survey instruments measure demand for specific pricing tiers and feature bundles, revealing which value combinations customers would actually choose across hypothetical product configurations."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "item_offered"
        ],
        "properties": {
          "item_offered": {
            "type": "string"
          },
          "eligible_region": {
            "type": "string"
          },
          "seller": {
            "type": "string"
          },
          "business_function": {
            "type": "string"
          },
          "valid_from": {
            "type": "string",
            "format": "date"
          },
          "valid_through": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/value-proposition",
      "@type": "mif:EntityType",
      "name": "value-proposition",
      "base": "semantic",
      "description": "A value proposition mapping offerings to customer jobs, pains and gains",
      "negative_examples": [
        "Demand for K-12 tutoring and supplemental-instruction software rose following widely reported pandemic-era learning-loss data, with district purchasing initially subsidized heavily by federal ESSER relief funds; demand growth has since moderated as ESSER funding wound down through its 2024 obligation deadline, shifting purchasing decisions back toward tighter district general-fund budgets. This funding-cliff dynamic is a commonly cited risk factor in K-12 edtech market-research commentary for any vendor whose growth relied heavily on the ESSER-funded period.",
        "This cohort screened for owners or sole financial decision-makers at businesses with fewer than 50 employees, yielding 650 qualified respondents for a study measuring unaided and aided brand awareness of accounting-software vendors. Quotas were set to match US Census Bureau small-business industry distribution rather than allowing a convenience sample skewed toward any single vertical.",
        "Enterprise SaaS segments are defined by buyers seeking flexible cloud deployment, multi-tenant architecture, and integration with existing enterprise tech stacks as core value propositions.",
        "This win-loss analysis covers a vertical-SaaS company's formal RFP process for selecting an embedded-payments infrastructure partner, drawn from interviews with the product and finance leadership who ran the evaluation. The recurring theme was that developer-experience quality, the API documentation and sandbox environment, evaluated directly by the SaaS company's own engineers during the RFP, weighed more heavily on the final decision than the headline per-transaction pricing rate, since integration engineering time was viewed as the larger real cost driver."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          },
          "service_type": {
            "type": "string"
          },
          "slogan": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/market-intelligence-report",
      "@type": "mif:EntityType",
      "name": "market-intelligence-report",
      "base": "semantic",
      "description": "A market-intelligence report or analysis",
      "aliases": [
        "market intelligence brief",
        "competitive intelligence report",
        "industry analyst report",
        "market research report"
      ],
      "exemplars": [
        "Pricing signals from adjacent enterprise software markets establish a willingness-to-pay range for a new category of infrastructure product",
        "An analyst quadrant report evaluates competing vendors in one category across execution and vision criteria, naming market leaders",
        "An annual industry index tracks aggregated billing data across hundreds of companies to compare single- versus multi-model revenue architectures"
      ],
      "negative_examples": [
        "Demand for managed-detection-and-response (MDR) in ransomware protection is documented in industry reports like CB Insights' cybersecurity threat analysis and Forrester Wave assessments of the MDR market.",
        "Healthcare payers represent a distinct market segment; industry intelligence reports track payer consolidation trends, reimbursement-policy shifts, and vendor adoption rates within this sector."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "date_published": {
            "type": "string",
            "format": "date"
          },
          "publisher": {
            "type": "string"
          },
          "about": {
            "type": "string"
          },
          "mentions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "is_based_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/market-data-source",
      "@type": "mif:EntityType",
      "name": "market-data-source",
      "base": "semantic",
      "description": "A catalog of market-intelligence data (REUSES schema:DataCatalog)",
      "negative_examples": [
        "Adobe Inc. is a publicly traded (NASDAQ: ADBE) software vendor headquartered in San Jose, California, whose Experience Cloud business unit, including the Marketo Engage marketing-automation product it acquired in 2018, competes in B2B marketing automation alongside its better-known Creative Cloud and Document Cloud lines, going up against HubSpot and Salesforce Marketing Cloud primarily at the upper end of the enterprise segment, where Marketo's pre-acquisition legacy footprint remains concentrated. CrowdStrike Holdings, Inc. is a similarly publicly traded (NASDAQ: CRWD) vendor in an unrelated space: a cloud-native endpoint and cloud-security company headquartered in Austin, Texas, built around its Falcon platform for endpoint detection and response, threat intelligence, and managed security services. It competes most directly with legacy endpoint-protection vendors and other EDR/XDR platforms, and has faced heightened scrutiny of platform reliability since a widely reported July 2024 content-update outage disrupted Windows systems globally.",
        "Demand for predictive-maintenance IoT platforms among manufacturers has grown as unplanned-downtime cost data, widely cited industry figures put average unplanned downtime cost in the tens of thousands of dollars per hour for large facilities, has made a stronger internal business case for capital investment in sensor instrumentation than reliability arguments alone previously achieved. This demand is most active among facilities that have already digitized other operations (ERP, MES) and are extending that digitization to the equipment layer rather than starting instrumentation from scratch.",
        "Sensor Tower's mobile-gaming report tracks in-app-purchase revenue, downloads, and monetization-mechanic trends across free-to-play mobile game genres, drawing on Sensor Tower's own app-store data-panel methodology, aggregated download and spend estimation rather than direct publisher-disclosed figures for most titles. The report is a standard secondary source in mobile-gaming competitive analysis, with the caveat that non-publisher-disclosed titles' figures are Sensor Tower's own estimation rather than confirmed revenue.",
        "This segment covers organizations of roughly 200-2,000 employees that lack an in-house 24/7 security operations center but face compliance pressure (cyber insurance questionnaires, SOC 2, industry regulation) requiring continuous threat monitoring. These buyers typically outsource detection and response entirely to a managed security provider rather than building a hybrid model, distinguishing them from larger enterprises that often run a hybrid in-house SOC augmented by an MDR vendor for after-hours coverage.",
        "This win-loss analysis covers manufacturing-facility pilots of an industrial-IoT monitoring platform that did or did not convert to a plant-wide rollout, based on interviews with plant operations managers who ran the pilot evaluation. The recurring theme identified among non-converting pilots was integration friction with the facility's existing SCADA/PLC vendor ecosystem discovered only during the pilot itself, rather than any dissatisfaction with the sensor data or dashboard quality, indicating pre-sales technical discovery had under-scoped the integration effort required."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "provider": {
            "type": "string"
          },
          "dataset": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "measurement_technique": {
            "type": "string"
          },
          "date_modified": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/survey-instrument",
      "@type": "mif:EntityType",
      "name": "survey-instrument",
      "base": "procedural",
      "description": "A survey instrument \u2014 a research plan specification",
      "negative_examples": [
        "A surveyed cohort of 250 manufacturing plant managers is gathered using a multi-question screening protocol that filters for facility size and recent technology-evaluation activity to ensure respondent relevance to IoT adoption studies.",
        "Clinical procurement leads at healthcare systems are characterized as decision-makers; capturing their preferences requires a structured interview protocol covering budget authority, risk tolerance, and vendor-certification requirements.",
        "The K-12 edtech segment is researched using survey instruments that measure teacher adoption rates, student engagement outcomes, and curriculum-fit perceptions to guide product roadmap decisions.",
        "Observability platforms communicate unified value propositions through surveys and buyer interviews, emphasizing single-pane-of-glass visibility, AI-driven insights, and cost reduction as key differentiators."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "measurement_technique": {
            "type": "string"
          },
          "about": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/win-loss-analysis",
      "@type": "mif:EntityType",
      "name": "win-loss-analysis",
      "base": "episodic",
      "description": "A win-loss analysis episode \u2014 post-decision interviews with won/lost prospects",
      "negative_examples": [
        "Win-loss discussion guides are survey instruments used to conduct structured interviews with customers about their vendor-selection reasoning, competitive comparisons, and deal-outcome drivers."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "about": {
            "type": "string"
          },
          "date_created": {
            "type": "string",
            "format": "date"
          },
          "mentions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  ],
  "relationships": {
    "analyzes-competitor": {
      "@id": "mif:relationship/analyzes-competitor",
      "@type": "mif:Relationship",
      "name": "analyzes-competitor",
      "description": "A win-loss-analysis analyzes a competitor (schema:about)",
      "from": [
        "mif:entityType/win-loss-analysis"
      ],
      "to": [
        "mif:entityType/competitor"
      ],
      "symmetric": false
    },
    "based-on-source": {
      "@id": "mif:relationship/based-on-source",
      "@type": "mif:Relationship",
      "name": "based-on-source",
      "description": "A market-intelligence-report is based on a market-data-source (schema:isBasedOn)",
      "from": [
        "mif:entityType/market-intelligence-report"
      ],
      "to": [
        "mif:entityType/market-data-source"
      ],
      "symmetric": false
    },
    "covers-segment": {
      "@id": "mif:relationship/covers-segment",
      "@type": "mif:Relationship",
      "name": "covers-segment",
      "description": "A market-intelligence-report covers a segment (schema:about)",
      "from": [
        "mif:entityType/market-intelligence-report"
      ],
      "to": [
        "mif:entityType/segment"
      ],
      "symmetric": false
    },
    "targets-audience": {
      "@id": "mif:relationship/targets-audience",
      "@type": "mif:Relationship",
      "name": "targets-audience",
      "description": "A value-proposition targets a buyer-persona (schema:audience)",
      "from": [
        "mif:entityType/value-proposition"
      ],
      "to": [
        "mif:entityType/buyer-persona"
      ],
      "symmetric": false
    },
    "tracks-competitive-force": {
      "@id": "mif:relationship/tracks-competitive-force",
      "@type": "mif:Relationship",
      "name": "tracks-competitive-force",
      "description": "A competitor tracks a competitive-force (schema:knowsAbout)",
      "from": [
        "mif:entityType/competitor"
      ],
      "to": [
        "mif:entityType/competitive-force"
      ],
      "symmetric": false
    },
    "item-offered": {
      "@id": "mif:relationship/item-offered",
      "@type": "mif:Relationship",
      "name": "item-offered",
      "description": "Market-demand is for an offered service-offering (schema:itemOffered)",
      "from": [
        "mif:entityType/market-demand"
      ],
      "to": [
        "mif:entityType/service-offering"
      ],
      "symmetric": false
    },
    "maintains-brand": {
      "@id": "mif:relationship/maintains-brand",
      "@type": "mif:Relationship",
      "name": "maintains-brand",
      "description": "A competitor maintains a brand (schema:brand / gr:hasBrand)",
      "from": [
        "mif:entityType/competitor"
      ],
      "to": [
        "mif:entityType/brand"
      ],
      "symmetric": false
    },
    "operates-in": {
      "@id": "mif:relationship/operates-in",
      "@type": "mif:Relationship",
      "name": "operates-in",
      "description": "A service-offering operates in a segment (schema:areaServed, extended to segment)",
      "from": [
        "mif:entityType/service-offering"
      ],
      "to": [
        "mif:entityType/segment"
      ],
      "symmetric": false
    },
    "provides-service": {
      "@id": "mif:relationship/provides-service",
      "@type": "mif:Relationship",
      "name": "provides-service",
      "description": "A competitor provides a service-offering (inverse of schema:provider)",
      "from": [
        "mif:entityType/competitor"
      ],
      "to": [
        "mif:entityType/service-offering"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(segment|vertical|buyer size|price band|market segment)\\b",
        "suggest_entity": "mif:entityType/segment",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(competitor|incumbent|rival vendor|market player)\\b",
        "suggest_entity": "mif:entityType/competitor",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(buyer persona|target audience|ICP|jobs[- ]to[- ]be[- ]done)\\b",
        "suggest_entity": "mif:entityType/buyer-persona",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(TAM|SAM|SOM|total addressable market|market siz(e|ing))\\b",
        "suggest_entity": "mif:entityType/sizing-estimate",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(five forces|bargaining power|threat of substitutes|new entrants)\\b",
        "suggest_entity": "mif:entityType/competitive-force",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/5",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(market report|landscape analysis|competitive intelligence report)\\b",
        "suggest_entity": "mif:entityType/market-intelligence-report",
        "suggest_namespace": "_semantic/reports"
      },
      {
        "@id": "mif:pattern/6",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(questionnaire|survey instrument|conjoint|MaxDiff|NPS survey)\\b",
        "suggest_entity": "mif:entityType/survey-instrument",
        "suggest_namespace": "_procedural/research"
      },
      {
        "@id": "mif:pattern/7",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(respondent|screener|n=\\d+|qualified respondents)\\b",
        "suggest_entity": "mif:entityType/respondent-segment",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/8",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(value proposition|jobs addressed|pains relieved|gains created)\\b",
        "suggest_entity": "mif:entityType/value-proposition",
        "suggest_namespace": "_semantic/market"
      },
      {
        "@id": "mif:pattern/9",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(win[- ]loss|win rate|deal review|loss reasons)\\b",
        "suggest_entity": "mif:entityType/win-loss-analysis",
        "suggest_namespace": "_episodic/research"
      },
      {
        "@id": "mif:pattern/10",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(syndicated|panel data|transaction data|data provider)\\b",
        "suggest_entity": "mif:entityType/market-data-source",
        "suggest_namespace": "_semantic/market"
      }
    ]
  }
}