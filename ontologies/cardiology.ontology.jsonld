    {
      "@id": "mif:entityType/echocardiography-study",
      "@type": "mif:EntityType",
      "name": "echocardiography-study",
      "base": "episodic",
      "description": "A structured bundle of cardiac echocardiography measurement data",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/clinical-observation"
      ],
      "schema": {
        "required": [
          "study_id",
          "modality",
          "observation_id",
          "code",
          "value"
        ],
        "properties": {
          "study_id": {
            "type": "string"
          },
          "modality": {
            "type": "string"
          },
          "member_measurements": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "ejection_fraction": {
            "type": "number"
          },
          "study_date": {
            "type": "string",
            "format": "date"
          },
          "observation_id": {
            "type": "string",
            "description": "Inherited from clinical-observation (same value as study_id)"
          },
          "code": {
            "type": "string",
            "description": "Inherited from clinical-observation: the LOINC code for this study"
          },
          "value": {
            "type": "string",
            "description": "Inherited from clinical-observation"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/ecg-finding",
      "@type": "mif:EntityType",
      "name": "ecg-finding",
      "base": "episodic",
      "description": "A structured electrical measurement bundle from a 12-lead ECG",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/clinical-observation"
      ],
      "schema": {
        "required": [
          "pr_interval_ms",
          "qrs_duration_ms",
          "observation_id",
          "code",
          "value"
        ],
        "properties": {
          "pr_interval_ms": {
            "type": "number"
          },
          "qrs_duration_ms": {
            "type": "number"
          },
          "qt_interval_ms": {
            "type": "number"
          },
          "qtc_ms": {
            "type": "number"
          },
          "impression": {
            "type": "string"
          },
          "observation_id": {
            "type": "string",
            "description": "Inherited from clinical-observation"
          },
          "code": {
            "type": "string",
            "description": "Inherited from clinical-observation: the LOINC code for this panel"
          },
          "value": {
            "type": "string",
            "description": "Inherited from clinical-observation"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/cardiac-catheterization-study",
      "@type": "mif:EntityType",
      "name": "cardiac-catheterization-study",
      "base": "episodic",
      "description": "The execution of an invasive diagnostic cardiac catheterization protocol",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/research-procedure"
      ],
      "schema": {
        "required": [
          "study_id",
          "access_site",
          "name"
        ],
        "properties": {
          "study_id": {
            "type": "string"
          },
          "access_site": {
            "type": "string"
          },
          "hemodynamic_findings": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "pre_cath_diagnosis": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Inherited from research-procedure: the procedure name (e.g. 'Cardiac catheterization')"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/cardiovascular-endpoint-event",
      "@type": "mif:EntityType",
      "name": "cardiovascular-endpoint-event",
      "base": "episodic",
      "description": "A standardized cardiovascular clinical-trial endpoint event",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "schema": {
        "required": [
          "event_type",
          "event_date"
        ],
        "properties": {
          "event_type": {
            "type": "string"
          },
          "event_date": {
            "type": "string",
            "format": "date"
          },
          "death_classification": {
            "type": "string"
          },
          "adjudication_source": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/nyha-functional-class",
      "@type": "mif:EntityType",
      "name": "nyha-functional-class",
      "base": "semantic",
      "description": "New York Heart Association functional capacity classification",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/scored"
      ],
      "schema": {
        "required": [
          "nyha_class"
        ],
        "properties": {
          "nyha_class": {
            "type": "string",
            "enum": [
              "I",
              "II",
              "III",
              "IV"
            ]
          },
          "assessment_date": {
            "type": "string",
            "format": "date"
          },
          "objective_assessment": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/cardiovascular-clinical-finding",
      "@type": "mif:EntityType",
      "name": "cardiovascular-clinical-finding",
      "base": "semantic",
      "description": "A point-in-time clinical finding distinct from a structured measurement (SNOMED CT's finding branch, architecturally distinct from ICD-11's disorder branch)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/clinical-observation"
      ],
      "schema": {
        "required": [
          "finding_type",
          "value",
          "observation_id",
          "code"
        ],
        "properties": {
          "finding_type": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "observation_id": {
            "type": "string",
            "description": "Inherited from clinical-observation"
          },
          "code": {
            "type": "string",
            "description": "Inherited from clinical-observation: the SNOMED CT finding code (same value as finding_type)"
          }
        }
      }
    }
  ],
  "relationships": {
    "occurs_within": {
      "@id": "mif:relationship/occurs_within",
      "@type": "mif:Relationship",
      "name": "occurs_within",
      "description": "A clinical activity occurs within a clinical encounter (finding-intermediary-layering-spec.json)",
      "from": [
        "mif:entityType/cardiac-catheterization-study"
      ],
      "to": [
        "mif:entityType/clinical-encounter"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(hypertension|ischemic heart disease|coronary artery disease|arrhythmia|heart failure|cardiomyopathy)\\b",
        "suggest_entity": "mif:entityType/hypertensive-disease",
        "suggest_namespace": "_semantic/cardiology-disorders"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(echocardiogram|echocardiography|2D echo|ejection fraction)\\b",
        "suggest_entity": "mif:entityType/echocardiography-study",
        "suggest_namespace": "_episodic/cardiology-studies"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(ECG|EKG|electrocardiogram|QRS|QT interval|PR interval)\\b",
        "suggest_entity": "mif:entityType/ecg-finding",
        "suggest_namespace": "_episodic/cardiology-studies"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(cardiac catheterization|coronary angiography|PCI)\\b",
        "suggest_entity": "mif:entityType/cardiac-catheterization-study",
        "suggest_namespace": "_episodic/cardiology-studies"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(NYHA class|New York Heart Association functional class)\\b",
        "suggest_entity": "mif:entityType/nyha-functional-class",
        "suggest_namespace": "_semantic/cardiology-functional-status"
      }
    ]
  }
}