{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "aliases": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "exemplars": {
      "@id": "skos:example",
      "@container": "@set"
    },
    "negative_examples": {
      "@id": "https://mif-spec.dev/ns/ontology#negativeExample",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/trend-analysis",
  "@type": "mif:Ontology",
  "identifier": "trend-analysis",
  "version": "0.3.0",
  "description": "Strategic foresight and trend-analysis domain ontology \u2014 signals, drivers, trends, scenarios, forecasts",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "foresight": {
          "@id": "mif:namespace/semantic/foresight",
          "@type": "mif:Namespace",
          "name": "foresight",
          "description": "Signals, drivers, trends, megatrends, uncertainties, and derived foresight artifacts",
          "type_hint": "semantic",
          "children": {
            "curves": {
              "@id": "mif:namespace/semantic/foresight/curves",
              "@type": "mif:Namespace",
              "name": "curves",
              "description": "Adoption / maturity curves (S-curve, hype cycle)",
              "type_hint": "semantic"
            },
            "forecasts": {
              "@id": "mif:namespace/semantic/foresight/forecasts",
              "@type": "mif:Namespace",
              "name": "forecasts",
              "description": "Forecasts and projected future outcomes",
              "type_hint": "semantic"
            },
            "scenarios": {
              "@id": "mif:namespace/semantic/foresight/scenarios",
              "@type": "mif:Namespace",
              "name": "scenarios",
              "description": "Plausible future narratives and scenario sets",
              "type_hint": "semantic"
            },
            "horizons": {
              "@id": "mif:namespace/semantic/foresight/horizons",
              "@type": "mif:Namespace",
              "name": "horizons",
              "description": "Three-Horizons temporal planning zones",
              "type_hint": "semantic"
            },
            "implications": {
              "@id": "mif:namespace/semantic/foresight/implications",
              "@type": "mif:Namespace",
              "name": "implications",
              "description": "Cascading consequences mapped from change (futures wheel)",
              "type_hint": "semantic"
            },
            "visions": {
              "@id": "mif:namespace/semantic/foresight/visions",
              "@type": "mif:Namespace",
              "name": "visions",
              "description": "Normative preferred future states (backcasting)",
              "type_hint": "semantic"
            }
          }
        }
      }
    },
    "procedural": {
      "@id": "mif:namespace/procedural",
      "@type": "mif:Namespace",
      "name": "procedural",
      "children": {
        "roadmaps": {
          "@id": "mif:namespace/procedural/roadmaps",
          "@type": "mif:Namespace",
          "name": "roadmaps",
          "description": "Time-sequenced strategic and technology roadmaps",
          "type_hint": "procedural"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/signal",
      "@type": "mif:EntityType",
      "name": "signal",
      "base": "semantic",
      "description": "A weak signal: a concrete local artifact or event hinting at change",
      "aliases": [
        "adoption signal",
        "market signal",
        "momentum signal",
        "trend indicator"
      ],
      "exemplars": [
        "A newly published open specification gains thousands of repository stars within weeks, signaling strong but still unproven practitioner interest",
        "A vendor's AI-augmented feature entering open beta with claimed large time savings signals accelerating automation in its category",
        "A community's chat-platform membership grows by a meaningful percentage within a year, evidencing accelerating mainstream adoption"
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "observation"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "observation": {
            "type": "string"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "observed_date": {
            "type": "string",
            "format": "date"
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "novelty": {
            "type": "string",
            "enum": [
              "weak",
              "emerging",
              "strengthening"
            ]
          },
          "geographic_scope": {
            "type": "string"
          },
          "related_driver": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/driver",
      "@type": "mif:EntityType",
      "name": "driver",
      "base": "semantic",
      "description": "A driver of change: a broad long-term force shaping the future",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "time_horizon": {
            "type": "string"
          },
          "impact_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "evidence_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "certainty_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/trend",
      "@type": "mif:EntityType",
      "name": "trend",
      "base": "semantic",
      "description": "A trend: a currently visible direction of change (the canonical generic)",
      "aliases": [
        "market trend",
        "adoption trend",
        "industry direction",
        "forecast",
        "trajectory",
        "market signal"
      ],
      "exemplars": [
        "An analyst firm predicts a technology category will reach half of deployments within three years",
        "Survey data shows adoption rising year over year while trust declines",
        "Global spending in a market segment exceeds a milestone with double-digit growth",
        "Vendors consolidate through acquisitions as a product category matures"
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "direction"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "maturity": {
            "type": "string",
            "enum": [
              "emerging",
              "mainstream",
              "mature",
              "declining"
            ]
          },
          "scope": {
            "type": "string"
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "strength": {
            "type": "string",
            "enum": [
              "weak",
              "moderate",
              "strong"
            ]
          },
          "first_observed": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/megatrend",
      "@type": "mif:EntityType",
      "name": "megatrend",
      "base": "semantic",
      "description": "A megatrend: a long-term structural transformation operating over a decade or more",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "temporal_scale": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "sub_trends": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_megatrends": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "policy_domains_affected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_reviewed": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/emerging-issue",
      "@type": "mif:EntityType",
      "name": "emerging-issue",
      "base": "semantic",
      "description": "An emerging issue: a novel phenomenon gaining recognition before it becomes a trend",
      "aliases": [
        "emerging risk",
        "open research problem",
        "unresolved technical issue",
        "nascent challenge"
      ],
      "exemplars": [
        "Provenance tracking and temporal validity remain the two hardest unsolved problems for a widely deployed category of AI system",
        "A newly public specification differentiates on real technical grounds but is still building adoption against a better-funded competing standard",
        "Contract explosion and organizational adoption friction are documented failure modes that drove an entire testing approach's evolution"
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "novelty_stage": {
            "type": "string"
          },
          "recognition_level": {
            "type": "string"
          },
          "competing_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "first_identified": {
            "type": "string",
            "format": "date"
          },
          "source_signal": {
            "type": "string"
          },
          "policy_relevance": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/wild-card",
      "@type": "mif:EntityType",
      "name": "wild-card",
      "base": "semantic",
      "description": "A wild card: a low-probability, high-impact rupture event",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "impact_domain"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "probability_estimate": {
            "type": "string",
            "enum": [
              "very-low",
              "low"
            ]
          },
          "impact_level": {
            "type": "string",
            "enum": [
              "high",
              "very-high",
              "extreme"
            ]
          },
          "impact_domain": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "trigger_conditions": {
            "type": "string"
          },
          "preparedness_notes": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/critical-uncertainty",
      "@type": "mif:EntityType",
      "name": "critical-uncertainty",
      "base": "semantic",
      "description": "A critical uncertainty: a high-impact factor that is genuinely unpredictable, used as a scenario axis",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "impact_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "uncertainty_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "axis_pole_low": {
            "type": "string"
          },
          "axis_pole_high": {
            "type": "string"
          },
          "related_drivers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scenarios_generated": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/adoption-curve",
      "@type": "mif:EntityType",
      "name": "adoption-curve",
      "base": "semantic",
      "description": "An adoption / maturity curve positioning a subject on an S-curve or hype cycle",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "subject",
          "model"
        ],
        "properties": {
          "subject": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "enum": [
              "rogers-s-curve",
              "gartner-hype-cycle"
            ]
          },
          "current_phase": {
            "type": "string"
          },
          "adopter_segment": {
            "type": "string",
            "enum": [
              "innovators",
              "early-adopters",
              "early-majority",
              "late-majority",
              "laggards"
            ]
          },
          "time_to_plateau": {
            "type": "string"
          },
          "critical_mass_reached": {
            "type": "boolean"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/forecast",
      "@type": "mif:EntityType",
      "name": "forecast",
      "base": "semantic",
      "description": "A forecast: a projected future outcome grounded in signals, drivers, and trends",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/timeline"
      ],
      "schema": {
        "required": [
          "statement",
          "horizon"
        ],
        "properties": {
          "statement": {
            "type": "string"
          },
          "horizon": {
            "type": "string"
          },
          "confidence_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "basis_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "basis_drivers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scenario_type": {
            "type": "string",
            "enum": [
              "baseline",
              "alternative",
              "wildcard"
            ]
          },
          "created_date": {
            "type": "string",
            "format": "date"
          },
          "author": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/scenario",
      "@type": "mif:EntityType",
      "name": "scenario",
      "base": "semantic",
      "description": "A scenario: a plausible, internally consistent future narrative",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name",
          "horizon"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "narrative": {
            "type": "string"
          },
          "horizon": {
            "type": "string"
          },
          "scenario_type": {
            "type": "string",
            "enum": [
              "baseline",
              "alternative",
              "aspirational",
              "collapse"
            ]
          },
          "critical_uncertainties_used": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_drivers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "plausibility_rationale": {
            "type": "string"
          },
          "world_state": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/horizon",
      "@type": "mif:EntityType",
      "name": "horizon",
      "base": "semantic",
      "description": "A horizon: a Three-Horizons temporal planning zone (H1/H2/H3)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "label",
          "horizon_type"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "horizon_type": {
            "type": "string",
            "enum": [
              "h1",
              "h2",
              "h3"
            ]
          },
          "time_span": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dominant_system": {
            "type": "string"
          },
          "key_innovations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mindset_type": {
            "type": "string"
          },
          "transition_triggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/implication",
      "@type": "mif:EntityType",
      "name": "implication",
      "base": "semantic",
      "description": "An implication: a cascading consequence of a change (futures wheel ring)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name",
          "parent_change"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "parent_change": {
            "type": "string"
          },
          "impact_domain": {
            "type": "string"
          },
          "steep_category": {
            "type": "string",
            "enum": [
              "social",
              "technological",
              "environmental",
              "economic",
              "political"
            ]
          },
          "valence": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "neutral",
              "mixed"
            ]
          },
          "probability_estimate": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/vision",
      "@type": "mif:EntityType",
      "name": "vision",
      "base": "semantic",
      "description": "A vision: a desired or preferred future state used as a backcasting anchor",
      "traits": [
        "mif:trait/cited",
        "mif:trait/stakeholders"
      ],
      "schema": {
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "target_horizon": {
            "type": "string"
          },
          "normative_basis": {
            "type": "string"
          },
          "stakeholders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "backcasting_pathway": {
            "type": "string"
          },
          "key_milestones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "values_underpinning": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/roadmap",
      "@type": "mif:EntityType",
      "name": "roadmap",
      "base": "procedural",
      "description": "A roadmap: a time-sequenced action plan working backward from a vision",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/timeline"
      ],
      "schema": {
        "required": [
          "name",
          "scope"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "target_vision": {
            "type": "string"
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "time_horizon": {
            "type": "string"
          },
          "technology_areas": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "resource_requirements": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_updated": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  ],
  "relationships": {
    "causes": {
      "@id": "mif:relationship/causes",
      "@type": "mif:Relationship",
      "name": "causes",
      "description": "A driver causes a trend (IFTF: drivers produce trends/signals)",
      "from": [
        "mif:entityType/driver"
      ],
      "to": [
        "mif:entityType/trend"
      ],
      "symmetric": false
    },
    "matures_into": {
      "@id": "mif:relationship/matures_into",
      "@type": "mif:Relationship",
      "name": "matures_into",
      "description": "A signal matures into a trend (IFTF: weak signal strengthens into a visible trend)",
      "from": [
        "mif:entityType/signal"
      ],
      "to": [
        "mif:entityType/trend"
      ],
      "symmetric": false
    },
    "indicates": {
      "@id": "mif:relationship/indicates",
      "@type": "mif:Relationship",
      "name": "indicates",
      "description": "A signal indicates a driver (IFTF: signals are symptoms of drivers)",
      "from": [
        "mif:entityType/signal"
      ],
      "to": [
        "mif:entityType/driver"
      ],
      "symmetric": false
    },
    "placed_on": {
      "@id": "mif:relationship/placed_on",
      "@type": "mif:Relationship",
      "name": "placed_on",
      "description": "A trend is placed on an adoption-curve (Rogers/Gartner: a trend is positioned on an S-curve or hype cycle)",
      "from": [
        "mif:entityType/trend"
      ],
      "to": [
        "mif:entityType/adoption-curve"
      ],
      "symmetric": false
    },
    "projected_as": {
      "@id": "mif:relationship/projected_as",
      "@type": "mif:Relationship",
      "name": "projected_as",
      "description": "A trend is projected as a forecast",
      "from": [
        "mif:entityType/trend"
      ],
      "to": [
        "mif:entityType/forecast"
      ],
      "symmetric": false
    },
    "shaped_by": {
      "@id": "mif:relationship/shaped_by",
      "@type": "mif:Relationship",
      "name": "shaped_by",
      "description": "A megatrend is shaped by a driver (a megatrend aggregates structural drivers)",
      "from": [
        "mif:entityType/megatrend"
      ],
      "to": [
        "mif:entityType/driver"
      ],
      "symmetric": false
    },
    "contains": {
      "@id": "mif:relationship/contains",
      "@type": "mif:Relationship",
      "name": "contains",
      "description": "A megatrend contains a trend (near-term trends express a megatrend)",
      "from": [
        "mif:entityType/megatrend"
      ],
      "to": [
        "mif:entityType/trend"
      ],
      "symmetric": false
    },
    "synthesizes": {
      "@id": "mif:relationship/synthesizes",
      "@type": "mif:Relationship",
      "name": "synthesizes",
      "description": "A scenario synthesizes its driving forces (built from drivers and megatrends)",
      "from": [
        "mif:entityType/scenario"
      ],
      "to": [
        "mif:entityType/driver",
        "mif:entityType/megatrend"
      ],
      "symmetric": false
    },
    "incorporated_in": {
      "@id": "mif:relationship/incorporated_in",
      "@type": "mif:Relationship",
      "name": "incorporated_in",
      "description": "A wild-card is incorporated in a scenario (wild-card scenarios are a planning technique)",
      "from": [
        "mif:entityType/wild-card"
      ],
      "to": [
        "mif:entityType/scenario"
      ],
      "symmetric": false
    },
    "disrupts": {
      "@id": "mif:relationship/disrupts",
      "@type": "mif:Relationship",
      "name": "disrupts",
      "description": "A wild-card disrupts a trend or megatrend (it ruptures established trajectories)",
      "from": [
        "mif:entityType/wild-card"
      ],
      "to": [
        "mif:entityType/trend",
        "mif:entityType/megatrend"
      ],
      "symmetric": false
    },
    "constrains": {
      "@id": "mif:relationship/constrains",
      "@type": "mif:Relationship",
      "name": "constrains",
      "description": "A critical-uncertainty constrains and differentiates the scenario space (Shell/GBN 2x2 axis)",
      "from": [
        "mif:entityType/critical-uncertainty"
      ],
      "to": [
        "mif:entityType/scenario"
      ],
      "symmetric": false
    },
    "generates": {
      "@id": "mif:relationship/generates",
      "@type": "mif:Relationship",
      "name": "generates",
      "description": "A driver produces a trend (IFTF: drivers precipitate visible trends)",
      "from": [
        "mif:entityType/driver"
      ],
      "to": [
        "mif:entityType/trend"
      ],
      "symmetric": false
    },
    "grounds": {
      "@id": "mif:relationship/grounds",
      "@type": "mif:Relationship",
      "name": "grounds",
      "description": "A driver grounds a forecast (IFTF: drivers/trends are building blocks of forecasts)",
      "from": [
        "mif:entityType/driver"
      ],
      "to": [
        "mif:entityType/forecast"
      ],
      "symmetric": false
    },
    "informs": {
      "@id": "mif:relationship/informs",
      "@type": "mif:Relationship",
      "name": "informs",
      "description": "A scenario informs a vision (OECD-OPSI: scenarios reveal futures from which a preferred future is selected)",
      "from": [
        "mif:entityType/scenario"
      ],
      "to": [
        "mif:entityType/vision"
      ],
      "symmetric": false
    },
    "operationalizes": {
      "@id": "mif:relationship/operationalizes",
      "@type": "mif:Relationship",
      "name": "operationalizes",
      "description": "A vision operationalizes into a roadmap (backcasting works backward from a vision to a time-sequenced roadmap)",
      "from": [
        "mif:entityType/vision"
      ],
      "to": [
        "mif:entityType/roadmap"
      ],
      "symmetric": false
    },
    "produces": {
      "@id": "mif:relationship/produces",
      "@type": "mif:Relationship",
      "name": "produces",
      "description": "A trend produces an implication (Futures Wheel: a trend produces cascading implications)",
      "from": [
        "mif:entityType/trend"
      ],
      "to": [
        "mif:entityType/implication"
      ],
      "symmetric": false
    },
    "specializes": {
      "@id": "mif:relationship/specializes",
      "@type": "mif:Relationship",
      "name": "specializes",
      "description": "A megatrend specializes a trend (rdfs:subClassOf \u2014 megatrend is a structural subtype of trend)",
      "from": [
        "mif:entityType/megatrend"
      ],
      "to": [
        "mif:entityType/trend"
      ],
      "symmetric": false
    },
    "intensifies": {
      "@id": "mif:relationship/intensifies",
      "@type": "mif:Relationship",
      "name": "intensifies",
      "description": "A wild-card intensifies a critical-uncertainty (rdfs:subClassOf \u2014 a wild card is a low-probability, very-high-impact subtype of critical uncertainty)",
      "from": [
        "mif:entityType/wild-card"
      ],
      "to": [
        "mif:entityType/critical-uncertainty"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(weak signal|signal of change|early indicator)\\b",
        "suggest_entity": "mif:entityType/signal",
        "suggest_namespace": "_semantic/foresight"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(driver of change|STEEP|long-term force)\\b",
        "suggest_entity": "mif:entityType/driver",
        "suggest_namespace": "_semantic/foresight"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(trend|direction of change|trend radar)\\b",
        "suggest_entity": "mif:entityType/trend",
        "suggest_namespace": "_semantic/foresight"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(hype cycle|trough of disillusionment|crossing the chasm|S-curve|early adopter)\\b",
        "suggest_entity": "mif:entityType/adoption-curve",
        "suggest_namespace": "_semantic/foresight/curves"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(forecast|projected (future|to)|expected to reach)\\b",
        "suggest_entity": "mif:entityType/forecast",
        "suggest_namespace": "_semantic/foresight/forecasts"
      },
      {
        "@id": "mif:pattern/5",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(megatrend|mega[- ]trend|structural transformation|decade[- ]long trend)\\b",
        "suggest_entity": "mif:entityType/megatrend",
        "suggest_namespace": "_semantic/foresight"
      },
      {
        "@id": "mif:pattern/6",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(scenario|plausible future|strategic uncertainty|world in 20\\d\\d)\\b",
        "suggest_entity": "mif:entityType/scenario",
        "suggest_namespace": "_semantic/foresight/scenarios"
      },
      {
        "@id": "mif:pattern/7",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(wild[- ]?card|black swan|low[- ]probability.*high[- ]impact|rupture event)\\b",
        "suggest_entity": "mif:entityType/wild-card",
        "suggest_namespace": "_semantic/foresight"
      }
    ]
  }
}