{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "aliases": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "exemplars": {
      "@id": "skos:example",
      "@container": "@set"
    },
    "negative_examples": {
      "@id": "https://mif-spec.dev/ns/ontology#negativeExample",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/engineering-base",
  "@type": "mif:Ontology",
  "identifier": "engineering-base",
  "version": "0.2.0",
  "description": "Shared engineering supertypes \u2014 the MIF-compliant intermediate layer the engineering domains extend",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "architecture": {
          "@id": "mif:namespace/semantic/architecture",
          "@type": "mif:Namespace",
          "name": "architecture",
          "description": "System architecture and component designs",
          "type_hint": "semantic"
        },
        "patterns": {
          "@id": "mif:namespace/semantic/patterns",
          "@type": "mif:Namespace",
          "name": "patterns",
          "description": "Design and architectural patterns",
          "type_hint": "semantic"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/component",
      "@type": "mif:EntityType",
      "name": "component",
      "base": "semantic",
      "description": "A software/system component, module, or service",
      "negative_examples": [
        "Service-to-service authentication and traffic management were previously implemented inconsistently, with each team hand-rolling its own TLS setup and retry logic in application code; the decision adopts Istio as a service mesh, injecting an Envoy sidecar into every service pod to enforce mutual TLS uniformly and centralize traffic-management policy as declarative Kubernetes resources rather than application code, rejecting a shared client library approach because it still requires every team to actually adopt and keep the library current rather than enforcing the policy mesh-wide regardless of any team's participation. Separately, the order-processing workflow previously called inventory, payment, and shipping services synchronously in sequence, so the customer-facing request's latency summed all three downstream calls and any one outage blocked order placement entirely; the decision adopts an event-driven architecture publishing an OrderPlaced event to Kafka for each downstream service to consume independently, decoupling the order service's own availability from any single downstream service's.",
        "The circuit breaker pattern wraps calls to failure-prone dependencies in a state machine that stops forwarding requests (open state) once a failure rate threshold is crossed, preventing cascading resource exhaustion in the caller."
      ],
      "traits": [
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "name",
          "responsibility"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Component name"
          },
          "responsibility": {
            "type": "string",
            "description": "Single responsibility description"
          },
          "dependencies": {
            "type": "array",
            "description": "List of component dependencies",
            "items": {
              "type": "string"
            }
          },
          "interfaces": {
            "type": "array",
            "description": "Public interfaces/APIs",
            "items": {
              "type": "string"
            }
          },
          "owner": {
            "type": "string",
            "description": "Team or person owning this component"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/architectural-decision",
      "@type": "mif:EntityType",
      "name": "architectural-decision",
      "base": "semantic",
      "description": "An architectural decision with full context",
      "traits": [
        "mif:trait/dated",
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "decision",
          "rationale"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "description": "The decision made"
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made"
          },
          "alternatives": {
            "type": "array",
            "description": "Alternatives considered",
            "items": {
              "type": "object"
            }
          },
          "consequences": {
            "type": "object",
            "description": "Known consequences and trade-offs"
          },
          "status": {
            "type": "string",
            "description": "Decision status",
            "enum": [
              "proposed",
              "accepted",
              "deprecated",
              "superseded"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/design-pattern",
      "@type": "mif:EntityType",
      "name": "design-pattern",
      "base": "semantic",
      "description": "A design pattern or architectural pattern",
      "negative_examples": [
        "Medallion architecture, a pattern popularized by Databricks, organizes a lakehouse into three progressively refined layers: a Bronze layer holding raw, unmodified ingested data as a durable historical record; a Silver layer holding cleaned, deduplicated, and conformed data joined across sources; and a Gold layer holding business-level, often aggregated tables ready for direct consumption by BI tools and analytics. The pattern gives every layer a single clear responsibility and lets a pipeline bug at the Silver or Gold stage be fixed and rerun from Bronze without needing to re-extract from the original source."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "pattern_name",
          "context",
          "solution"
        ],
        "properties": {
          "pattern_name": {
            "type": "string"
          },
          "context": {
            "type": "string",
            "description": "When to use this pattern"
          },
          "solution": {
            "type": "string",
            "description": "How the pattern solves the problem"
          },
          "consequences": {
            "type": "object",
            "description": "Trade-offs and implications"
          },
          "related_patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/delivery-metric",
      "@type": "mif:EntityType",
      "name": "delivery-metric",
      "base": "semantic",
      "description": "A delivery, reliability, or operations metric (e.g. DORA four/five keys, SLO/SLI, MTTR, throughput)",
      "negative_examples": [
        "This decision replaces static per-metric alert thresholds with SLO error-budget burn-rate alerting, following the multi-window, multi-burn-rate approach documented in the Google SRE Workbook, on the rationale that resource-level thresholds correlate poorly with actual user-facing impact and are a leading cause of both alert fatigue and missed incidents. Adopting burn-rate alerting requires every service to first have a defined SLO and SLI, which the decision treats as a prerequisite migration cost rather than something retrofitted incident by incident.",
        "A retry-with-exponential-backoff-and-jitter pattern resends failed requests with progressively longer delays plus randomized jitter, reducing thundering herd effects when many clients retry simultaneously after an outage.",
        "A capacity planning review discipline is a recurring meeting where teams forecast resource needs (compute, storage, personnel) for the next quarter based on growth trends and project commitments.",
        "The freely published Google SRE Workbook contains a specific chapter document defining the multi-window, multi-burn-rate SLO alerting scheme that has become the reference implementation most teams cite when adopting burn-rate-based paging, distinguished from the Workbook's separate chapters covering on-call practice, incident response, and postmortems. Because it is openly published rather than paywalled, this particular chapter is the document most frequently linked directly, rather than summarized secondhand, whenever a team's own alerting documentation cites its source methodology.",
        "DORA began as an independent research program co-founded by Nicole Forsgren, Jez Humble, and Gene Kim, publishing the annual State of DevOps report before being acquired by Google in 2018 and continuing its research under Google Cloud. Its methodology is explicitly empirical, correlating survey responses about organizational practices against the outcomes those organizations self-report, rather than prescriptive best-practice guidance asserted without a stated evidence base."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "metric_name"
        ],
        "properties": {
          "metric_name": {
            "type": "string"
          },
          "definition": {
            "type": "string",
            "description": "What the metric measures"
          },
          "benchmark": {
            "type": "string",
            "description": "Target or elite-tier value"
          },
          "source": {
            "type": "string",
            "description": "Originating framework or study"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/engineering-practice",
      "@type": "mif:EntityType",
      "name": "engineering-practice",
      "base": "semantic",
      "description": "An organizational, cultural, or operating practice (e.g. blameless postmortems, you-build-it-you-run-it, data mesh, federated governance)",
      "negative_examples": [
        "This discipline requires an architecturally-significant change to be written up as an Architecture Decision Record, the decision, its rationale, alternatives considered, and accepted consequences, and reviewed by stakeholders before implementation begins, rather than letting significant architectural choices emerge implicitly from code review of the implementation alone. Its purpose is capturing the reasoning at the time a decision is made, since reviewing the resulting implementation typically only shows what was built, not why alternatives were rejected. Teams commonly gate it on a significance threshold to avoid overhead on routine changes. Separately, the Incident Command System assigns named roles for a major incident, an Incident Commander who coordinates and owns decisions, a Communications Lead handling status updates, and Subject Matter Experts actively debugging, rather than leaving coordination implicit or defaulting to whoever is most senior, preventing the failure mode where multiple engineers investigate in parallel with no one tracking overall status or managing communication.",
        "A central data engineering team had become a bottleneck for every new dataset request, so the organization decided to decentralize data ownership to domain teams, each publishing its own governed, discoverable data product instead of routing every schema change through the central team, accepting the upfront cost of shared self-serve infrastructure (a catalog, standardized publishing tooling, governance policy) once the number of source systems and consumer teams had outgrown what one central team could scale to serve. Separately, a platform team that had been operating and upgrading its own Kubernetes control plane on self-managed EC2 instances decided to migrate to Amazon EKS so AWS takes over control-plane patching, freeing the team's capacity for developer-facing tooling; continuing self-managed Kubernetes with better upgrade automation was rejected because it reduces toil without removing the team's on-call responsibility for control-plane incidents.",
        "Charity Majors, co-founder and CTO of Honeycomb, is one of the most prominent public advocates for the high-cardinality, structured-event framing of observability, frequently arguing against the 'three pillars' framing as a symptom of legacy tooling limitations rather than a natural taxonomy; she previously worked in operations engineering at Parse and Facebook and co-authored the O'Reilly book 'Observability Engineering.' John Allspaw is widely credited with popularizing the blameless postmortem during his tenure as an engineering leader at Etsy, drawing on human-factors and resilience-engineering research, notably Sidney Dekker's 'Just Culture', to argue that incident retrospectives should focus on the systemic conditions that made an error possible rather than identifying an individual to blame; his writing is commonly cited as the origin point most teams trace their own postmortem approach back to, even when they adopted it via Google's SRE book instead.",
        "Google is the organization credited with originating Site Reliability Engineering internally beginning in the early 2000s, attributed to Ben Treynor Sloss, and later publishing much of its internal practice as the freely available 'Site Reliability Engineering' and 'The Site Reliability Workbook' books, now widely cited reference sources across the industry well beyond Google itself. A substantial share of the disciplines and conventions documented elsewhere, error budget policy, SLO review, blameless postmortems, alert rule review, trace their most commonly cited source directly back to these two books."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "practice_name"
        ],
        "properties": {
          "practice_name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "What the practice is"
          },
          "evidence": {
            "type": "string",
            "description": "Empirical support or outcome"
          },
          "origin": {
            "type": "string",
            "description": "Originating model, study, or author"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/process-discipline",
      "@type": "mif:EntityType",
      "name": "process-discipline",
      "base": "semantic",
      "description": "A governance or production-readiness discipline (e.g. PRR, ORR, change enablement, acceptance criteria, stewardship cadence)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "discipline_name"
        ],
        "properties": {
          "discipline_name": {
            "type": "string"
          },
          "purpose": {
            "type": "string",
            "description": "What the discipline governs"
          },
          "criteria": {
            "type": "string",
            "description": "Acceptance or gating criteria"
          },
          "stage": {
            "type": "string",
            "description": "Lifecycle stage where it applies"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/control",
      "@type": "mif:EntityType",
      "name": "control",
      "base": "semantic",
      "description": "A control or safeguard governing a component, artifact, or asset (security, data-governance, or compliance control)",
      "negative_examples": [
        "etcd is a distributed, consistent key-value store serving as Kubernetes' primary datastore, holding the full cluster state via Raft consensus replicated across an odd-sized member set that requires a quorum to commit a write; kube-apiserver is its only direct client, so etcd's availability and write latency become a hard dependency for the whole control plane's responsiveness. Vault is a centralized secrets-management service that stores, generates, and brokers credentials, certificates, and encryption keys through short-lived, scoped leases rather than static values, using pluggable auth methods to decide what an authenticated client may read. It starts sealed after any restart and requires an unseal step via Shamir key fragments or an auto-unseal mechanism before serving any secret, deliberately limiting blast radius if underlying storage is compromised.",
        "This policy restricts production container builds to a defined, centrally-maintained set of approved base images rather than letting any team pull an arbitrary public image directly into a production Dockerfile, since an unvetted image is a supply-chain entry point outside the org's own scanning and patch cadence, a small approved set lets one team's patching effort protect every other product team depending on it. A base image not on the approved list requires a defined request-and-review process rather than being blocked permanently or allowed silently. Separately, this policy defines who is authorized to communicate externally about a production incident, what is shared at each stage, and the threshold criteria that trigger a more formal disclosure process beyond routine status-page updates, designating the incident commander or a specifically assigned communications lead as the sole channel and routing anything beyond a routine update through legal/compliance review first.",
        "A Change Advisory Board is a governance discipline where proposed production changes above a defined risk threshold are reviewed by a cross-functional group, operations, security, affected service owners, before being authorized to proceed, rather than left to the implementing team's own judgment alone; its purpose is catching cross-team impacts and scheduling conflicts the implementing team may not have visibility into, at the cost of a review-and-scheduling delay. High-deployment-frequency organizations commonly narrow this review to genuinely high-risk changes and pre-authorize routine ones. Similarly, this discipline requires a new or significantly changed service to pass a security team's design review before launch, examining the authentication model, data classification and encryption handling, and third-party dependency exposure at the design stage, because catching an architectural issue there is far cheaper than a pre-launch penetration test finding the same issue after the system is already built.",
        "Centralizing on Vault was chosen over continuing to let each team manage its own secret storage, because per-service stores made audit logging inconsistent, rotation manual and error-prone, and incident-response scoping dependent on tribal knowledge of each service's own configuration rather than a single, centrally queryable log. A cloud-native secrets manager per cloud provider was set aside for the initial rollout given the organization's existing multi-cloud footprint, where one provider-neutral secrets layer avoided vendor lock-in and inconsistent per-cloud tooling. The accepted trade-off is that Vault becomes a critical-path dependency whose own availability and disaster-recovery posture now directly gates every dependent service's ability to authenticate to its own backing resources.",
        "A documented plan to address identified security risks and compliance gaps through risk assessment, prioritization of remediation activities, and tracking of implementation progress against regulatory deadlines.",
        "AC-2 is one of the most frequently assessed controls in FedRAMP and other 800-53-based compliance programs because account lifecycle failures, most commonly disabled accounts for departed employees that are never actually deactivated, or shared service accounts with no individual accountability, are a recurring root cause in breach post-mortems. Its enhancements, such as AC-2(3) for automatic disabling of inactive accounts and AC-2(13) for disabling accounts of high-risk individuals, are frequently implemented via identity-governance tooling that ties account state directly to an HR system of record rather than a manually-maintained list."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "control_name"
        ],
        "properties": {
          "control_name": {
            "type": "string"
          },
          "control_type": {
            "type": "string",
            "description": "preventive / detective / corrective"
          },
          "framework_ref": {
            "type": "string",
            "description": "Originating framework or catalog (e.g. NIST 800-53 AC-2, SOC 2 CC6.1)"
          },
          "statement": {
            "type": "string",
            "description": "What the control requires"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/artifact",
      "@type": "mif:EntityType",
      "name": "artifact",
      "base": "semantic",
      "description": "A produced, content-addressable artifact (software package/build, dataset, model, report)",
      "negative_examples": [
        "Internal services currently communicate over synchronous REST/JSON; this decision adopts gRPC with Protocol Buffers for new internal service-to-service calls while keeping REST/JSON at the public edge, for a strongly typed schema shared across four languages plus generated client/server stubs that remove hand-written client libraries. REST with OpenAPI-generated clients, and GraphQL federation, were both considered and rejected, accepting a steeper on-call debugging curve and a required protobuf schema-registry discipline in return. Separately, after cross-service refactors across dozens of independent repositories kept requiring coordinated multi-repo pull requests that drifted out of sync, the organization consolidated its services and shared libraries into a single monorepo with a unified build graph that only rebuilds the subset affected by a given change, polyrepo with stricter version discipline, and a hybrid grouping of only tightly-coupled services, were both rejected as still requiring the cross-repo coordination the decision was meant to eliminate.",
        "This guide migrates a production Elasticsearch 6.x cluster to OpenSearch, the Apache 2.0-licensed fork created after Elastic's 2021 license change, using OpenSearch's documented reindex-from-remote capability to pull data directly from the source cluster rather than a dump-and-restore approach for large indices, and calls out verifying client library compatibility against OpenSearch's API surface before cutover. A separate guide migrates functionality out of a monolithic application incrementally using the strangler fig pattern rather than attempting a rewrite: a reverse proxy sits in front of the monolith, and each migrated capability is extracted into its own service one at a time, with each extraction required to independently pass a parity check against the monolith's existing behavior before the proxy's routing is updated to send that capability's traffic to the new service.",
        "dbt's run_results.json records, for a given invocation, exactly which models ran, their execution status and timing, and the compiled SQL actually executed against the warehouse, which lineage tools combine with manifest.json's static dependency graph to reconstruct which specific run produced a model's current table state, letting a team tie a downstream data-quality issue back to the exact git commit and run responsible. Similarly, this record links a generated CycloneDX SBOM to the exact source commit, build tool versions, and timestamp that produced it, embedding them directly in the SBOM's own metadata rather than distributing it as a standalone file with no verifiable connection back to its build; without that linkage an SBOM's claims are unfalsifiable, so it is attached to the specific artifact digest it describes via the OCI referrers API, letting a scanner resolve by digest rather than by name or version alone.",
        "Fluent Bit is a lightweight log and metrics shipper written in C specifically to minimize the resource footprint of running one instance per host or per Kubernetes node, in contrast to its heavier sibling project Fluentd, which trades a larger footprint for a broader Ruby plugin ecosystem. It is commonly deployed as the log-collection layer feeding into an OpenTelemetry Collector or directly into a backend, parsing container stdout/stderr and structured application logs before forwarding them onward.",
        "Trunk-based development is an engineering practice where all developers commit to a single main branch frequently (multiple times per day) rather than maintaining long-lived feature branches, reducing merge conflicts and enabling continuous integration.",
        "A 2017 GitLab incident where a primary database was accidentally deleted through a misconfigured backup deletion script, causing hours of data loss and recovery work, resulting in improved runbook procedures.",
        "The RED method specifies three request-level metrics-Rate (requests per second), Errors (failure rate), and Duration (response time distribution)-for microservice monitoring.",
        "Raw kernel trace events exported in JSON format enable analysis of system call latency, memory allocation patterns, and I/O performance characteristics."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "artifact_type": {
            "type": "string",
            "description": "build / package / image / dataset / model / report"
          },
          "digest": {
            "type": "string",
            "description": "Content hash (e.g. sha256:...)"
          },
          "uri": {
            "type": "string",
            "description": "Locator for the artifact"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/policy",
      "@type": "mif:EntityType",
      "name": "policy",
      "base": "semantic",
      "description": "A policy: a rule governing access, retention, classification, or change, enforced across the lifecycle",
      "negative_examples": [
        "A retention and deletion audit cadence discipline schedules a recurring review, commonly quarterly, verifying that automated purge jobs are actually running as configured and actually deleting the data categories they're supposed to, since a silently failing purge job can leave regulated data past its limit with no alert of its own; the audit samples tables, confirms the oldest remaining row sits within the limit, and files a remediation ticket for any table found holding data past its window. Alert rule review periodically audits the full set of production alerting rules against a fixed checklist, does each link a maintained runbook, has it fired recently or is its rarity explicitly justified, what fraction of firings were true positives, specifically to counter rules accumulating over time without ever being pruned, treating alert-set bloat as a direct contributor to alert fatigue and missed incidents.",
        "This corrective control requires an automated, scheduled job that identifies and deletes records exceeding their classified data category's configured retention limit, rather than relying on a manual or ad hoc deletion process that depends on someone remembering to run it, so the limit is enforced consistently even as data volume and table count grow beyond what manual review could realistically track. It is typically validated by confirming the purge job's run history shows successful, on-schedule execution and by periodically sampling tables to confirm no row exceeds its category's retention window, the same evidence the retention audit cadence discipline that oversees this control relies on.",
        "Error budget policy is an engineering practice where teams track the difference between their SLO and actual uptime, using the remaining budget to decide whether to prioritize new features or stability work.",
        "IA-5's password-related enhancements were substantially reshaped by NIST SP 800-63B's 2017 shift away from mandatory periodic rotation and arbitrary complexity rules toward length-based requirements and screening against known-breached password lists, and current implementation guidance for IA-5 typically references 800-63B rather than older composition-rule guidance. The control also governs certificate-based and token-based authenticators, including revocation timelines when an authenticator is compromised or an individual's access is terminated.",
        "ISO 27001's access-control clause requires an organization to document a formal access-control policy addressing user registration and deregistration, access provisioning aligned to business need and least privilege, and periodic access-rights review, mirroring the intent of NIST 800-53's AC-2 control though structured differently under ISO's Annex A control catalog. A typical certified organization's policy under this clause requires quarterly access recertification for privileged roles and immediate deprovisioning tied to an HR offboarding trigger."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "policy_name"
        ],
        "properties": {
          "policy_name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "description": "What the policy governs"
          },
          "enforcement": {
            "type": "string",
            "description": "Mechanism that enforces it (policy-as-code, gate, ABAC tag)"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/provenance",
      "@type": "mif:EntityType",
      "name": "provenance",
      "base": "semantic",
      "description": "A provenance or attestation record binding an artifact to how it was produced (SLSA/in-toto, OpenLineage)",
      "negative_examples": [
        "A Great Expectations checkpoint run emits a validation-result record, a structured JSON snapshot of which expectations passed or failed for the batch, including observed values on failures, published to a Data Docs site and often retained so a specific historical run's outcome can be pulled up directly rather than only the pipeline's current state. Because each run generates its own record, teams can build a time series showing exactly when a given expectation first started failing. OpenLineage's dataset facets do something similar at the dataset level: point-in-time schema, row-count, and source metadata attached to a run's input or output reference, forming a lightweight snapshot of what a dataset looked like at that run rather than a copy of the data itself, comparing snapshots across runs is how schema drift or unexpected row-count shifts tied to a specific run get surfaced.",
        "A detective control periodically verifies that an SLI's underlying metric is still receiving data and producing valid values, catching silent instrumentation breakage that would otherwise show as a false perfect SLO.",
        "An oncall handoff discipline defines how on-call operators transfer responsibility at shift changes, including status briefing on active incidents, escalation contact procedures, and access credential handoff protocols.",
        "A runbook for addressing TLS certificate expiration incidents includes steps to check certificate expiration dates, renew certificates before expiry, update certificate references in load balancers and services, and verify HTTPS connectivity post-renewal.",
        "SLSA defines cumulative levels of assurance: a basic level only requires the build process to generate an attestation at all, while higher levels require the build to run on a hardened, isolated platform resistant to tampering by any single build script or dependency, directly addressing the class of risk the SolarWinds build-system compromise illustrated, where a compromised build environment defeated code-signing as a standalone integrity guarantee. The framework was motivated by real supply-chain incidents (SolarWinds, the 2018 event-stream npm compromise) and by Executive Order 14028, which specifically called for provenance and integrity requirements in the federal software supply chain. GitHub Actions' native build-provenance feature and npm's Sigstore-based package provenance are both practical implementations letting a project claim a specific level under the framework.",
        "The flaw arose because OpenSSL's heartbeat handler trusted a client-supplied length field without validating it against the actual payload size, letting an attacker request more memory than was sent and receive adjacent heap contents in the reply, with no trace left in server logs. Because the vulnerable code had been present in OpenSSL for over two years before discovery, an unknown but potentially large amount of private key material and session data across the internet's HTTPS infrastructure may have been silently exposed. It prompted a coordinated internet-wide certificate reissuance effort and remains one of the most cited examples of the systemic risk posed by widely-shared open-source cryptographic libraries."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "subject"
        ],
        "properties": {
          "subject": {
            "type": "string",
            "description": "The artifact or entity the provenance describes"
          },
          "builder": {
            "type": "string",
            "description": "The system/identity that produced it"
          },
          "predicate_type": {
            "type": "string",
            "description": "Attestation predicate (e.g. SLSA provenance, in-toto, OpenLineage run)"
          },
          "materials": {
            "type": "array",
            "description": "Inputs/materials consumed",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  ],
  "traits": {
    "versioned": {
      "@id": "mif:trait/versioned",
      "@type": "mif:Trait",
      "name": "versioned",
      "description": "Adds version tracking fields",
      "fields": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+.*$"
        },
        "changelog": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "documented": {
      "@id": "mif:trait/documented",
      "@type": "mif:Trait",
      "name": "documented",
      "description": "Adds documentation reference",
      "fields": {
        "documentation_url": {
          "type": "string",
          "format": "uri"
        },
        "readme_path": {
          "type": "string"
        }
      }
    },
    "dated": {
      "@id": "mif:trait/dated",
      "@type": "mif:Trait",
      "name": "dated",
      "description": "Adds decision/event date",
      "fields": {
        "decision_date": {
          "type": "string",
          "format": "date"
        },
        "review_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "cited": {
      "@id": "mif:trait/cited",
      "@type": "mif:Trait",
      "name": "cited",
      "description": "Requires citations/sources",
      "requires": [
        "citations"
      ]
    }
  },
  "relationships": {
    "depends_on": {
      "@id": "mif:relationship/depends_on",
      "@type": "mif:Relationship",
      "name": "depends_on",
      "description": "Component dependency relationship",
      "from": [
        "mif:entityType/component"
      ],
      "to": [
        "mif:entityType/component",
        "mif:entityType/technology"
      ],
      "symmetric": false
    },
    "implements": {
      "@id": "mif:relationship/implements",
      "@type": "mif:Relationship",
      "name": "implements",
      "description": "Component implements a pattern or decision",
      "from": [
        "mif:entityType/component"
      ],
      "to": [
        "mif:entityType/design-pattern",
        "mif:entityType/architectural-decision"
      ],
      "symmetric": false
    },
    "governs": {
      "@id": "mif:relationship/governs",
      "@type": "mif:Relationship",
      "name": "governs",
      "description": "A control or policy governs a component or artifact",
      "from": [
        "mif:entityType/control",
        "mif:entityType/policy"
      ],
      "to": [
        "mif:entityType/component",
        "mif:entityType/artifact"
      ],
      "symmetric": false
    },
    "attests": {
      "@id": "mif:relationship/attests",
      "@type": "mif:Relationship",
      "name": "attests",
      "description": "A provenance record attests an artifact",
      "from": [
        "mif:entityType/provenance"
      ],
      "to": [
        "mif:entityType/artifact"
      ],
      "symmetric": false
    },
    "derived_from": {
      "@id": "mif:relationship/derived_from",
      "@type": "mif:Relationship",
      "name": "derived_from",
      "description": "Artifact lineage \u2014 an artifact is derived from another",
      "from": [
        "mif:entityType/artifact"
      ],
      "to": [
        "mif:entityType/artifact"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Factory|Singleton|Observer|Repository|Strategy|Decorator)\\s+Pattern\\b",
        "suggest_entity": "mif:entityType/design-pattern",
        "suggest_namespace": "_semantic/patterns"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(CQRS|Event\\s+Sourcing|Saga)\\b",
        "suggest_entity": "mif:entityType/design-pattern",
        "suggest_namespace": "_semantic/patterns"
      }
    ]
  }
}