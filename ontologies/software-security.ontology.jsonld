  "@id": "mif:ontology/software-security",
  "@type": "mif:Ontology",
  "identifier": "software-security",
  "version": "0.4.0",
  "description": "Software-security domain ontology \u2014 the software-facing slice of security: threats, vulnerabilities, controls, actors, indicators, supply-chain, incidents, frameworks",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "threats": {
          "@id": "mif:namespace/semantic/threats",
          "@type": "mif:Namespace",
          "name": "threats",
          "description": "Attack tactics, malware, and threat techniques",
          "type_hint": "semantic"
        },
        "vulnerabilities": {
          "@id": "mif:namespace/semantic/vulnerabilities",
          "@type": "mif:Namespace",
          "name": "vulnerabilities",
          "description": "CVE vulnerability instances",
          "type_hint": "semantic"
        },
        "weaknesses": {
          "@id": "mif:namespace/semantic/weaknesses",
          "@type": "mif:Namespace",
          "name": "weaknesses",
          "description": "CWE weakness classes",
          "type_hint": "semantic"
        },
        "controls": {
          "@id": "mif:namespace/semantic/controls",
          "@type": "mif:Namespace",
          "name": "controls",
          "description": "Security controls and safeguards",
          "type_hint": "semantic"
        },
        "actors": {
          "@id": "mif:namespace/semantic/actors",
          "@type": "mif:Namespace",
          "name": "actors",
          "description": "Threat actors and intrusion sets",
          "type_hint": "semantic"
        },
        "indicators": {
          "@id": "mif:namespace/semantic/indicators",
          "@type": "mif:Namespace",
          "name": "indicators",
          "description": "Indicators of compromise",
          "type_hint": "semantic"
        },
        "supply-chain": {
          "@id": "mif:namespace/semantic/supply-chain",
          "@type": "mif:Namespace",
          "name": "supply-chain",
          "description": "Supply-chain (C-SCRM) risks",
          "type_hint": "semantic"
        }
      }
    },
    "episodic": {
      "@id": "mif:namespace/episodic",
      "@type": "mif:Namespace",
      "name": "episodic",
      "children": {
        "campaigns": {
          "@id": "mif:namespace/episodic/campaigns",
          "@type": "mif:Namespace",
          "name": "campaigns",
          "description": "Attack campaigns and threat-intelligence reports",
          "type_hint": "episodic"
        },
        "assessments": {
          "@id": "mif:namespace/episodic/assessments",
          "@type": "mif:Namespace",
          "name": "assessments",
          "description": "Security assessments and audits",
          "type_hint": "episodic"
        }
      }
    },
    "procedural": {
      "@id": "mif:namespace/procedural",
      "@type": "mif:Namespace",
      "name": "procedural",
      "children": {
        "policies": {
          "@id": "mif:namespace/procedural/policies",
          "@type": "mif:Namespace",
          "name": "policies",
          "description": "Security policies and plans of action",
          "type_hint": "procedural"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/attack-tactic",
      "@type": "mif:EntityType",
      "name": "attack-tactic",
      "base": "semantic",
      "description": "An adversary tactical objective (the why of a technique)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "tactic_id",
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tactic_id": {
            "type": "string"
          },
          "shortname": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "external_references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "techniques_count": {
            "type": "integer"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/attack-mitigation",
      "@type": "mif:EntityType",
      "name": "attack-mitigation",
      "base": "procedural",
      "description": "A course of action that mitigates one or more ATT&CK techniques",
      "negative_examples": [
        "Describes the range of techniques adversaries commonly employ to gain initial entry into a network, from social engineering via phishing to exploitation of unpatched systems and abuse of legitimate credentials."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "mitigation_id",
          "name"
        ],
        "properties": {
          "mitigation_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mitigates_techniques": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/malware",
      "@type": "mif:EntityType",
      "name": "malware",
      "base": "semantic",
      "description": "A malicious software family or instance",
      "negative_examples": [
        "Software features or system components that can be selectively restricted or disabled to prevent their abuse by adversaries, including legacy protocols, scripting engines, and unnecessary services.",
        "A large-scale compromise of a third-party managed file-transfer platform used by thousands of organizations, resulting in unauthorized data access and exfiltration through exploitation of a critical software vulnerability.",
        "Compromise of a widely-used open-source package through insertion of obfuscated malicious code in build scripts or test files, targeting a critical downstream dependency used by millions of systems.",
        "A coordinated multi-phase attack operation targeting critical infrastructure, using wiper-style payloads and network spreading techniques to cause widespread disruptive impact across interconnected systems.",
        "A legitimate domain registered to support a kill-switch mechanism, serving to disable or control the behavior of a self-replicating worm if the kill-switch domain can be contacted.",
        "An extortion and encryption attack offered as a service, where criminals provide the ransomware toolkit and infrastructure in exchange for a percentage of recovery payments from victims.",
        "Although Stuxnet itself is cataloged as malware, the operation behind it is a distinct threat-actor question: researchers and subsequent reporting have attributed its development and deployment to a joint nation-state operation involving the United States and Israel, targeting the Natanz enrichment facility's centrifuge configurations, though neither government has ever formally confirmed involvement. That attribution rests on converging circumstantial evidence, the exceptional engineering investment implied by four independently-weaponized Windows zero-days, the payload's narrow specificity to exact centrifuge configurations rather than indiscriminate damage, and the geopolitical context of covert action against Iran's nuclear program at the time, rather than any single conclusive technical artifact naming a group. The distinction matters operationally: cataloging the operators as a threat actor or intrusion set captures their motivations, capabilities, and continuity across campaigns, which a catalog entry for the malware payload alone does not."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "is_family": {
            "type": "boolean"
          },
          "malware_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "operating_system_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "implementation_languages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/vulnerability",
      "@type": "mif:EntityType",
      "name": "vulnerability",
      "base": "semantic",
      "description": "A CVE vulnerability instance in a product or component",
      "negative_examples": [
        "Because an SBOM by itself only enumerates which components are present, a consumer scanning it against a vulnerability database will flag every CVE associated with any listed component version, even when the vulnerable code path is never actually reachable in how the product uses that component. A VEX document is the artifact that lets the producing organization make and publish that reachability determination once, centrally, commonly in either the OpenVEX or CSAF (Common Security Advisory Framework) format, rather than every downstream consumer independently re-deriving the same 'not affected' conclusion, and it is increasingly requested by security teams doing vendor risk assessment specifically to filter SBOM-derived vulnerability noise down to the subset of findings that actually require action. The artifact's credibility depends on the producing organization actually performing and documenting a real reachability analysis, rather than defaulting every finding to 'not affected' without justification, a shortcut that downstream consumers and auditors have started to scrutinize."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "cve_id",
          "vulnerability_name"
        ],
        "properties": {
          "cve_id": {
            "type": "string"
          },
          "vulnerability_name": {
            "type": "string"
          },
          "weakness_class": {
            "type": "string"
          },
          "cvss_score": {
            "type": "number"
          },
          "affected_product": {
            "type": "string"
          },
          "affected_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "published_date": {
            "type": "string",
            "format": "date"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/weakness",
      "@type": "mif:EntityType",
      "name": "weakness",
      "base": "semantic",
      "description": "A CWE weakness class (a flaw type, distinct from a CVE instance)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "cwe_id",
          "weakness_name"
        ],
        "properties": {
          "cwe_id": {
            "type": "string"
          },
          "weakness_name": {
            "type": "string"
          },
          "abstraction_level": {
            "type": "string",
            "enum": [
              "pillar",
              "class",
              "base",
              "variant",
              "compound"
            ]
          },
          "description": {
            "type": "string"
          },
          "consequences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicable_platforms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "likelihood_of_exploit": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low",
              "unknown"
            ]
          },
          "related_weaknesses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-control",
      "@type": "mif:EntityType",
      "name": "security-control",
      "base": "semantic",
      "description": "A security control or safeguard (the security specialization of the generic engineering-base `control`)",
      "negative_examples": [
        "A prescriptive safeguard requires that code changes be reviewed and approved by a second person before merging, enforced through branch protection settings that reject pushes lacking required review status.",
        "An allowlist-based input validation design pattern rejects any input that does not match a known-safe pattern rather than trying to blacklist dangerous patterns, reducing the risk of bypass attacks.",
        "The failure to properly encode or sanitize user-supplied HTML and JavaScript in web application output, allowing an attacker to inject malicious scripts that execute in the browser of victim users."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/control"
      ],
      "schema": {
        "required": [
          "control_id",
          "control_name"
        ],
        "properties": {
          "control_id": {
            "type": "string"
          },
          "control_name": {
            "type": "string"
          },
          "control_family": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "implementation_guidance": {
            "type": "string"
          },
          "baseline": {
            "type": "string",
            "enum": [
              "low",
              "moderate",
              "high",
              "privacy"
            ]
          },
          "enhancements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/threat-actor",
      "@type": "mif:EntityType",
      "name": "threat-actor",
      "base": "semantic",
      "description": "A threat actor or intrusion set",
      "negative_examples": [
        "The shift from perimeter VPN access to a zero-trust model was motivated directly by incident patterns like the Colonial Pipeline breach, in which a single compromised VPN credential lacking multi-factor authentication granted an attacker broad network access rather than access scoped to a specific application, illustrating the structural risk of the perimeter model, where an attacker's lateral movement once inside is limited only by internal network segmentation rather than by any per-resource authorization check. The alternative of retaining the existing VPN while simply adding mandatory MFA was considered and partially adopted as an interim step, but was ultimately judged insufficient on its own, since it still grants broad network-level access rather than per-application, per-request authorization. The accepted trade-off is a more complex identity-aware proxy and policy-engine deployment, plus a multi-quarter migration period during which both the legacy VPN and the new zero-trust access path must be operated in parallel.",
        "Falco's responsibility is real-time detection rather than prevention: it evaluates a stream of kernel syscall events against a rule set, flagging, for example, a write to /etc/shadow, an outbound connection to an unexpected port, or a process attempting to disable a security tool, and emits alerts consumable by a SIEM or alerting pipeline, filling a runtime-visibility gap that static image scanning and admission-control policies like OPA/Gatekeeper cannot address, since those operate before a workload starts running. Because it operates at the kernel syscall level rather than instrumenting the application itself, it can detect malicious activity even inside a container whose application code has been compromised by a payload the image scanner never saw. Its default rule set is grounded in common ATT&CK-mapped container-escape and privilege-escalation techniques, and organizations commonly extend it with custom rules specific to their own workloads, making it a runtime security component in the deployed stack, not an actor or campaign in its own right.",
        "An organized series of coordinated attacks targeting multiple major corporations, employing sophisticated phishing and zero-day exploitation techniques to achieve intellectual property theft and surveillance access.",
        "A tiered command-and-control infrastructure consisting of multiple staged relay servers and domain registrations designed to obscure the true location and origin of attack communications.",
        "An attack vector leveraging weak credential validation at login endpoints, allowing unauthorized access through reuse of previously compromised username-password pairs across multiple services.",
        "A sophisticated, state-sponsored cyberweapon designed to target industrial control systems, featuring self-propagation across USB devices and zero-day exploitation of multiple operating system components.",
        "A continuous process of collecting, analyzing, and responding to security events and anomalies across an organization's infrastructure to detect unauthorized access, data exfiltration, and malicious activity.",
        "A large-scale retail data breach targeting millions of customer payment card records through exploitation of inadequately segmented network architecture and unpatched point-of-sale systems."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/attributed"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "threat_actor_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sophistication": {
            "type": "string"
          },
          "resource_level": {
            "type": "string"
          },
          "primary_motivation": {
            "type": "string"
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/attack-campaign",
      "@type": "mif:EntityType",
      "name": "attack-campaign",
      "base": "episodic",
      "description": "A grouping of adversarial behaviour over a period of time",
      "traits": [
        "mif:trait/timeline",
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "campaign_name"
        ],
        "properties": {
          "campaign_name": {
            "type": "string"
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "attributed_to": {
            "type": "string"
          },
          "objectives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/indicator-of-compromise",
      "@type": "mif:EntityType",
      "name": "indicator-of-compromise",
      "base": "semantic",
      "description": "An observable pattern that indicates malicious activity",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "pattern"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "pattern_type": {
            "type": "string"
          },
          "pattern_version": {
            "type": "string"
          },
          "valid_from": {
            "type": "string",
            "format": "date-time"
          },
          "valid_until": {
            "type": "string",
            "format": "date-time"
          },
          "indicator_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-infrastructure",
      "@type": "mif:EntityType",
      "name": "security-infrastructure",
      "base": "semantic",
      "description": "Adversary or defensive infrastructure (servers, domains, hosting)",
      "aliases": [
        "signing infrastructure",
        "verification infrastructure",
        "trust infrastructure",
        "package security infrastructure"
      ],
      "exemplars": [
        "A package manager automatically verifies a cryptographic checksum against a public transparency log before trusting a downloaded module",
        "An extension marketplace now requires developer-registered private-key signing on every future upload, rejecting anything unsigned",
        "An official plugin directory applies automated security review to listings but explicitly cannot verify every server a plugin might call"
      ],
      "negative_examples": [
        "The decision to enforce mTLS at the service-mesh layer, rather than requiring each service team to implement its own TLS and authentication logic, was driven by the goal of guaranteeing every internal connection is encrypted and cryptographically authenticated by workload identity regardless of an individual team's security maturity, since a single unauthenticated internal endpoint has historically been the entry point attackers use once they gain any initial foothold inside a network perimeter. The alternative considered, relying on perimeter-only security through network segmentation alone, was rejected because it provides no protection once an attacker achieves lateral movement past the perimeter, consistent with zero-trust architectural principles. The accepted trade-off is added mesh-sidecar operational complexity and per-request latency overhead, mitigated by the mesh's connection pooling and by scoping mTLS enforcement to sensitive namespaces first during rollout rather than enabling it cluster-wide on day one."
      ],
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "infrastructure_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-tool",
      "@type": "mif:EntityType",
      "name": "security-tool",
      "base": "semantic",
      "description": "A legitimate tool that can be used by adversaries or defenders",
      "aliases": [
        "verification tool",
        "signing tool",
        "attestation CLI tool",
        "package security tool"
      ],
      "exemplars": [
        "A package manager's chain-of-trust verifies a signed release manifest against trusted keys before installing anything, blocking by default on failure",
        "A command-line tool verifies a file's signature keylessly by pinning a certificate identity and issuer rather than a static key",
        "A package manager's opt-in attestation verification wraps another CLI tool to hard-fail an install when provenance verification fails"
      ],
      "negative_examples": [
        "A TLS/SSL fingerprint artifact associated with a particular remote-access framework, allowing defenders to identify command-and-control communications even when encrypted.",
        "Team servers are a legitimate and central feature of Cobalt Strike's design for authorized red-team operations, but leaked or cracked copies of the software are widely abused by criminal and nation-state operators to stand up their own command-and-control infrastructure, making 'Cobalt Strike team server' infrastructure common to both authorized penetration tests and real-world intrusions alike. Because the software supports extensive customization via 'malleable C2' profiles, defenders cannot rely solely on default network signatures and instead combine JA3/JARM TLS fingerprinting, known default SSL-certificate characteristics, and behavioral beacon-interval analysis to identify unauthorized team-server infrastructure exposed on the internet. Cataloged team-server infrastructure of this kind is a major input to internet-wide scanning-based threat-intelligence products that track adversary C2 footprints over time, the deployed server and its network footprint are the infrastructure being cataloged, distinct from the tool's software itself or any single operator using it."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tool_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tool_version": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/threat-intelligence-report",
      "@type": "mif:EntityType",
      "name": "threat-intelligence-report",
      "base": "episodic",
      "description": "A curated threat-intelligence report grouping related CTI objects",
      "negative_examples": [
        "Mean time to detect (MTTD) and dwell time together measure the elapsed time from when a breach occurs (or evidence of compromise is logged) to when security operations detect and confirm it, serving as a key indicator of detection capability maturity.",
        "A sophisticated, long-duration attack operation targeting industrial control systems and critical infrastructure, employing living-off-the-land techniques and prioritizing stealth and persistence over disruptive impact.",
        "A comprehensive analysis of a critical credential-compromise incident affecting a major credit-reporting organization, including technical indicators, attack timeline, and affected consumer record counts."
      ],
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "report_types": {
            "type": "array",
