{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/software-security",
  "@type": "mif:Ontology",
  "identifier": "software-security",
  "version": "0.2.0",
  "description": "Software-security domain ontology \u2014 the software-facing slice of security: threats, vulnerabilities, controls, actors, indicators, supply-chain, incidents, frameworks",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "threats": {
          "@id": "mif:namespace/semantic/threats",
          "@type": "mif:Namespace",
          "name": "threats",
          "description": "Attack tactics, malware, and threat techniques",
          "type_hint": "semantic"
        },
        "vulnerabilities": {
          "@id": "mif:namespace/semantic/vulnerabilities",
          "@type": "mif:Namespace",
          "name": "vulnerabilities",
          "description": "CVE vulnerability instances",
          "type_hint": "semantic"
        },
        "weaknesses": {
          "@id": "mif:namespace/semantic/weaknesses",
          "@type": "mif:Namespace",
          "name": "weaknesses",
          "description": "CWE weakness classes",
          "type_hint": "semantic"
        },
        "controls": {
          "@id": "mif:namespace/semantic/controls",
          "@type": "mif:Namespace",
          "name": "controls",
          "description": "Security controls and safeguards",
          "type_hint": "semantic"
        },
        "actors": {
          "@id": "mif:namespace/semantic/actors",
          "@type": "mif:Namespace",
          "name": "actors",
          "description": "Threat actors and intrusion sets",
          "type_hint": "semantic"
        },
        "indicators": {
          "@id": "mif:namespace/semantic/indicators",
          "@type": "mif:Namespace",
          "name": "indicators",
          "description": "Indicators of compromise",
          "type_hint": "semantic"
        },
        "supply-chain": {
          "@id": "mif:namespace/semantic/supply-chain",
          "@type": "mif:Namespace",
          "name": "supply-chain",
          "description": "Supply-chain (C-SCRM) risks",
          "type_hint": "semantic"
        }
      }
    },
    "episodic": {
      "@id": "mif:namespace/episodic",
      "@type": "mif:Namespace",
      "name": "episodic",
      "children": {
        "campaigns": {
          "@id": "mif:namespace/episodic/campaigns",
          "@type": "mif:Namespace",
          "name": "campaigns",
          "description": "Attack campaigns and threat-intelligence reports",
          "type_hint": "episodic"
        },
        "assessments": {
          "@id": "mif:namespace/episodic/assessments",
          "@type": "mif:Namespace",
          "name": "assessments",
          "description": "Security assessments and audits",
          "type_hint": "episodic"
        }
      }
    },
    "procedural": {
      "@id": "mif:namespace/procedural",
      "@type": "mif:Namespace",
      "name": "procedural",
      "children": {
        "policies": {
          "@id": "mif:namespace/procedural/policies",
          "@type": "mif:Namespace",
          "name": "policies",
          "description": "Security policies and plans of action",
          "type_hint": "procedural"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/attack-tactic",
      "@type": "mif:EntityType",
      "name": "attack-tactic",
      "base": "semantic",
      "description": "An adversary tactical objective (the why of a technique)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "tactic_id",
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tactic_id": {
            "type": "string"
          },
          "shortname": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "external_references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "techniques_count": {
            "type": "integer"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/attack-mitigation",
      "@type": "mif:EntityType",
      "name": "attack-mitigation",
      "base": "procedural",
      "description": "A course of action that mitigates one or more ATT&CK techniques",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "mitigation_id",
          "name"
        ],
        "properties": {
          "mitigation_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mitigates_techniques": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/malware",
      "@type": "mif:EntityType",
      "name": "malware",
      "base": "semantic",
      "description": "A malicious software family or instance",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "is_family": {
            "type": "boolean"
          },
          "malware_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "operating_system_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "implementation_languages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/vulnerability",
      "@type": "mif:EntityType",
      "name": "vulnerability",
      "base": "semantic",
      "description": "A CVE vulnerability instance in a product or component",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "cve_id",
          "vulnerability_name"
        ],
        "properties": {
          "cve_id": {
            "type": "string"
          },
          "vulnerability_name": {
            "type": "string"
          },
          "weakness_class": {
            "type": "string"
          },
          "cvss_score": {
            "type": "number"
          },
          "affected_product": {
            "type": "string"
          },
          "affected_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "published_date": {
            "type": "string",
            "format": "date"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/weakness",
      "@type": "mif:EntityType",
      "name": "weakness",
      "base": "semantic",
      "description": "A CWE weakness class (a flaw type, distinct from a CVE instance)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "cwe_id",
          "weakness_name"
        ],
        "properties": {
          "cwe_id": {
            "type": "string"
          },
          "weakness_name": {
            "type": "string"
          },
          "abstraction_level": {
            "type": "string",
            "enum": [
              "pillar",
              "class",
              "base",
              "variant",
              "compound"
            ]
          },
          "description": {
            "type": "string"
          },
          "consequences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicable_platforms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "likelihood_of_exploit": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low",
              "unknown"
            ]
          },
          "related_weaknesses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-control",
      "@type": "mif:EntityType",
      "name": "security-control",
      "base": "semantic",
      "description": "A security control or safeguard (the security specialization of the generic engineering-base `control`)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/control"
      ],
      "schema": {
        "required": [
          "control_id",
          "control_name"
        ],
        "properties": {
          "control_id": {
            "type": "string"
          },
          "control_name": {
            "type": "string"
          },
          "control_family": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "implementation_guidance": {
            "type": "string"
          },
          "baseline": {
            "type": "string",
            "enum": [
              "low",
              "moderate",
              "high",
              "privacy"
            ]
          },
          "enhancements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/threat-actor",
      "@type": "mif:EntityType",
      "name": "threat-actor",
      "base": "semantic",
      "description": "A threat actor or intrusion set",
      "traits": [
        "mif:trait/cited",
        "mif:trait/attributed"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "threat_actor_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sophistication": {
            "type": "string"
          },
          "resource_level": {
            "type": "string"
          },
          "primary_motivation": {
            "type": "string"
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/attack-campaign",
      "@type": "mif:EntityType",
      "name": "attack-campaign",
      "base": "episodic",
      "description": "A grouping of adversarial behaviour over a period of time",
      "traits": [
        "mif:trait/timeline",
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "campaign_name"
        ],
        "properties": {
          "campaign_name": {
            "type": "string"
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "attributed_to": {
            "type": "string"
          },
          "objectives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/indicator-of-compromise",
      "@type": "mif:EntityType",
      "name": "indicator-of-compromise",
      "base": "semantic",
      "description": "An observable pattern that indicates malicious activity",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name",
          "pattern"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "pattern_type": {
            "type": "string"
          },
          "pattern_version": {
            "type": "string"
          },
          "valid_from": {
            "type": "string",
            "format": "date-time"
          },
          "valid_until": {
            "type": "string",
            "format": "date-time"
          },
          "indicator_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-infrastructure",
      "@type": "mif:EntityType",
      "name": "security-infrastructure",
      "base": "semantic",
      "description": "Adversary or defensive infrastructure (servers, domains, hosting)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "infrastructure_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-tool",
      "@type": "mif:EntityType",
      "name": "security-tool",
      "base": "semantic",
      "description": "A legitimate tool that can be used by adversaries or defenders",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tool_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kill_chain_phases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tool_version": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/threat-intelligence-report",
      "@type": "mif:EntityType",
      "name": "threat-intelligence-report",
      "base": "episodic",
      "description": "A curated threat-intelligence report grouping related CTI objects",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "report_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "published": {
            "type": "string",
            "format": "date-time"
          },
          "object_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/supply-chain-risk",
      "@type": "mif:EntityType",
      "name": "supply-chain-risk",
      "base": "semantic",
      "description": "A cyber supply-chain (C-SCRM) supplier or component risk",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "risk_id",
          "risk_statement"
        ],
        "properties": {
          "risk_id": {
            "type": "string"
          },
          "risk_statement": {
            "type": "string"
          },
          "supplier_name": {
            "type": "string"
          },
          "component_type": {
            "type": "string"
          },
          "likelihood": {
            "type": "string",
            "enum": [
              "very-low",
              "low",
              "moderate",
              "high",
              "very-high"
            ]
          },
          "impact_level": {
            "type": "string",
            "enum": [
              "very-low",
              "low",
              "moderate",
              "high",
              "very-high"
            ]
          },
          "risk_response": {
            "type": "string",
            "enum": [
              "accept",
              "avoid",
              "mitigate",
              "share",
              "transfer"
            ]
          },
          "mitigation_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-policy",
      "@type": "mif:EntityType",
      "name": "security-policy",
      "base": "procedural",
      "description": "A security policy grounded in an OSCAL system security plan / profile",
      "traits": [
        "mif:trait/versioned",
        "mif:trait/documented",
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "policy_name"
        ],
        "properties": {
          "policy_name": {
            "type": "string"
          },
          "policy_version": {
            "type": "string"
          },
          "policy_status": {
            "type": "string"
          },
          "system_name": {
            "type": "string"
          },
          "system_id": {
            "type": "string"
          },
          "authorization_boundary": {
            "type": "string"
          },
          "control_implementations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "responsible_parties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-assessment",
      "@type": "mif:EntityType",
      "name": "security-assessment",
      "base": "episodic",
      "description": "A security assessment, audit, or test of a system",
      "traits": [
        "mif:trait/timeline",
        "mif:trait/cited",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "assessment_id"
        ],
        "properties": {
          "assessment_id": {
            "type": "string"
          },
          "assessment_subject": {
            "type": "string"
          },
          "assessment_scope": {
            "type": "string"
          },
          "assessment_activities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks_identified": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/poam",
      "@type": "mif:EntityType",
      "name": "poam",
      "base": "procedural",
      "description": "A plan of action and milestones tracking risks to remediation",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "poam_id",
          "system_id"
        ],
        "properties": {
          "poam_id": {
            "type": "string"
          },
          "system_id": {
            "type": "string"
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "observations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "poam_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "remediation_tracking": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-threat",
      "@type": "mif:EntityType",
      "name": "security-threat",
      "base": "semantic",
      "description": "A security threat, attack class, or vulnerability affecting the software lifecycle (SDLC-facing supertype refined by attack-tactic/weakness/vulnerability)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "schema": {
        "required": [
          "threat_name",
          "attack_vector"
        ],
        "properties": {
          "threat_name": {
            "type": "string"
          },
          "attack_vector": {
            "type": "string",
            "description": "How the threat is exploited"
          },
          "impact": {
            "type": "string",
            "description": "What an attacker gains or breaks"
          },
          "mitigation_summary": {
            "type": "string",
            "description": "Primary defenses against this threat"
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "attack_id": {
            "type": "string",
            "description": "ATT&CK technique/sub-technique (e.g. T1566) or CAPEC ID"
          },
          "tactic": {
            "type": "string",
            "description": "ATT&CK tactic / kill-chain phase"
          },
          "adversary": {
            "type": "string",
            "description": "Intrusion set / ATT&CK Group"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-framework",
      "@type": "mif:EntityType",
      "name": "security-framework",
      "base": "semantic",
      "description": "A security or assurance framework, taxonomy, or standard (e.g. OWASP Top 10, MITRE ATLAS, SLSA, NIST SSDF/CSF)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "schema": {
        "required": [
          "framework_name",
          "scope"
        ],
        "properties": {
          "framework_name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "description": "What the framework governs (e.g. application risk, supply-chain integrity, adversary TTPs)"
          },
          "maintainer": {
            "type": "string",
            "description": "Organization that maintains the framework"
          },
          "relationship": {
            "type": "string",
            "description": "How it relates to or composes with other frameworks"
          },
          "version": {
            "type": "string",
            "description": "Framework version/edition (e.g. CSF 2.0, OWASP Top 10:2025)"
          },
          "structure": {
            "type": "string",
            "description": "Framework structure (e.g. CSF: 6 functions / 22 categories / 106 subcategories)"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/security-incident",
      "@type": "mif:EntityType",
      "name": "security-incident",
      "base": "episodic",
      "description": "A security breach/incident carrying the VERIS four A's (Actor + Action + Asset + Attribute)",
      "traits": [
        "mif:trait/timeline",
        "mif:trait/stakeholders",
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "severity",
          "impact",
          "resolution"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "impact": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "actor": {
            "type": "string",
            "description": "VERIS Actor \u2014 external / internal / partner"
          },
          "action": {
            "type": "string",
            "description": "VERIS Action \u2014 malware / hacking / social / error / misuse"
          },
          "asset": {
            "type": "string",
            "description": "VERIS Asset \u2014 the device/data affected"
          },
          "attribute": {
            "type": "string",
            "description": "VERIS Attribute \u2014 how affected (CIA)"
          }
        }
      }
    }
  ],
  "relationships": {
    "attributed_to": {
      "@id": "mif:relationship/attributed_to",
      "@type": "mif:Relationship",
      "name": "attributed_to",
      "description": "A campaign is attributed to a threat actor (stix:attributed-to)",
      "from": [
        "mif:entityType/attack-campaign"
      ],
      "to": [
        "mif:entityType/threat-actor"
      ],
      "symmetric": false
    },
    "categorizes": {
      "@id": "mif:relationship/categorizes",
      "@type": "mif:Relationship",
      "name": "categorizes",
      "description": "A weakness class categorizes a vulnerability instance (CWE CanPrecede / rdfs:subClassOf)",
      "from": [
        "mif:entityType/weakness"
      ],
      "to": [
        "mif:entityType/vulnerability"
      ],
      "symmetric": false
    },
    "defines": {
      "@id": "mif:relationship/defines",
      "@type": "mif:Relationship",
      "name": "defines",
      "description": "A framework defines a control (OSCAL profile import->include-controls)",
      "from": [
        "mif:entityType/security-framework"
      ],
      "to": [
        "mif:entityType/security-control"
      ],
      "symmetric": false
    },
    "documents": {
      "@id": "mif:relationship/documents",
      "@type": "mif:Relationship",
      "name": "documents",
      "description": "A threat-intelligence report documents a campaign (STIX Report object_refs)",
      "from": [
        "mif:entityType/threat-intelligence-report"
      ],
      "to": [
        "mif:entityType/attack-campaign"
      ],
      "symmetric": false
    },
    "exploits": {
      "@id": "mif:relationship/exploits",
      "@type": "mif:Relationship",
      "name": "exploits",
      "description": "Malware exploits a vulnerability (stix:exploits, Malware -> Vulnerability)",
      "from": [
        "mif:entityType/malware"
      ],
      "to": [
        "mif:entityType/vulnerability"
      ],
      "symmetric": false
    },
    "hosts": {
      "@id": "mif:relationship/hosts",
      "@type": "mif:Relationship",
      "name": "hosts",
      "description": "Infrastructure hosts malware (stix:hosts, Infrastructure -> Malware)",
      "from": [
        "mif:entityType/security-infrastructure"
      ],
      "to": [
        "mif:entityType/malware"
      ],
      "symmetric": false
    },
    "indicates": {
      "@id": "mif:relationship/indicates",
      "@type": "mif:Relationship",
      "name": "indicates",
      "description": "An indicator of compromise indicates malware (stix:indicates, Indicator -> Malware)",
      "from": [
        "mif:entityType/indicator-of-compromise"
      ],
      "to": [
        "mif:entityType/malware"
      ],
      "symmetric": false
    },
    "mitigates_threat": {
      "@id": "mif:relationship/mitigates_threat",
      "@type": "mif:Relationship",
      "name": "mitigates_threat",
      "description": "A mitigation mitigates a threat technique (stix:mitigates, course-of-action -> attack-pattern)",
      "from": [
        "mif:entityType/attack-mitigation"
      ],
      "to": [
        "mif:entityType/security-threat"
      ],
      "symmetric": false
    },
    "mitigates": {
      "@id": "mif:relationship/mitigates",
      "@type": "mif:Relationship",
      "name": "mitigates",
      "description": "A control mitigates a vulnerability (RO:0000056 participates-in; OSCAL control satisfies risk)",
      "from": [
        "mif:entityType/security-control"
      ],
      "to": [
        "mif:entityType/vulnerability"
      ],
      "symmetric": false
    },
    "realizes": {
      "@id": "mif:relationship/realizes",
      "@type": "mif:Relationship",
      "name": "realizes",
      "description": "An incident realizes a threat (RO:0000056 participates-in)",
      "from": [
        "mif:entityType/security-incident"
      ],
      "to": [
        "mif:entityType/security-threat"
      ],
      "symmetric": false
    },
    "tracks": {
      "@id": "mif:relationship/tracks",
      "@type": "mif:Relationship",
      "name": "tracks",
      "description": "A POA&M tracks a vulnerability to remediation (OSCAL poam:risks / poam-item)",
      "from": [
        "mif:entityType/poam"
      ],
      "to": [
        "mif:entityType/vulnerability"
      ],
      "symmetric": false
    },
    "uses": {
      "@id": "mif:relationship/uses",
      "@type": "mif:Relationship",
      "name": "uses",
      "description": "A threat actor uses a security tool (stix:uses, threat-actor -> tool)",
      "from": [
        "mif:entityType/threat-actor"
      ],
      "to": [
        "mif:entityType/security-tool"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(CVE-\\d{4}-\\d{4,})\\b",
        "suggest_entity": "mif:entityType/vulnerability",
        "suggest_namespace": "_semantic/vulnerabilities"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\bCWE-\\d+\\b",
        "suggest_entity": "mif:entityType/weakness",
        "suggest_namespace": "_semantic/weaknesses"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(AC|AU|SC|SI|IA)-\\d+\\b",
        "suggest_entity": "mif:entityType/security-control",
        "suggest_namespace": "_semantic/controls"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(APT\\d+|Lazarus Group|FIN\\d+|Sandworm|Volt Typhoon)\\b",
        "suggest_entity": "mif:entityType/threat-actor",
        "suggest_namespace": "_semantic/actors"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Operation|Campaign)\\s+[A-Z][a-zA-Z]+\\b",
        "suggest_entity": "mif:entityType/attack-campaign",
        "suggest_namespace": "_episodic/campaigns"
      },
      {
        "@id": "mif:pattern/5",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(IOC|YARA|Sigma rule|STIX pattern|TLP:)\\b",
        "suggest_entity": "mif:entityType/indicator-of-compromise",
        "suggest_namespace": "_semantic/indicators"
      },
      {
        "@id": "mif:pattern/6",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(supply chain|SBOM|C-SCRM)\\b",
        "suggest_entity": "mif:entityType/supply-chain-risk",
        "suggest_namespace": "_semantic/supply-chain"
      },
      {
        "@id": "mif:pattern/7",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(pen test|red team|audit finding|compliance review)\\b",
        "suggest_entity": "mif:entityType/security-assessment",
        "suggest_namespace": "_episodic/assessments"
      },
      {
        "@id": "mif:pattern/8",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(acceptable use policy|data classification policy)\\b",
        "suggest_entity": "mif:entityType/security-policy",
        "suggest_namespace": "_procedural/policies"
      },
      {
        "@id": "mif:pattern/9",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(Mimikatz|WannaCry|Cobalt Strike|S\\d{4})\\b",
        "suggest_entity": "mif:entityType/malware",
        "suggest_namespace": "_semantic/threats"
      }
    ]
  }
}