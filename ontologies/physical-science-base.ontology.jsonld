{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/physical-science-base",
  "@type": "mif:Ontology",
  "identifier": "physical-science-base",
  "version": "0.1.0",
  "description": "Shared physics/astrophysics supertypes \u2014 the MIF-compliant intermediate layer plasma-physics and cosmology extend",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "physical-science": {
          "@id": "mif:namespace/semantic/physical-science",
          "@type": "mif:Namespace",
          "name": "physical-science",
          "description": "Physics/astrophysics classification and quantity shapes",
          "type_hint": "semantic"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/classification-scheme-entry",
      "@type": "mif:EntityType",
      "name": "classification-scheme-entry",
      "base": "semantic",
      "description": "A named, coded entry in a physics or astrophysics classification scheme \u2014 the shape plasma-physics's PACS 52.xx-grounded classification mints and cosmology's PACS 98.xx-grounded classification mints both independently converged on",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/categorized"
      ],
      "schema": {
        "required": [
          "scheme_code",
          "title"
        ],
        "properties": {
          "scheme_code": {
            "type": "string",
            "description": "The classification-scheme code (e.g. a PACS code)"
          },
          "title": {
            "type": "string"
          },
          "parent_section": {
            "type": "string",
            "description": "The parent section or heading within the classification scheme"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/physical-quantity",
      "@type": "mif:EntityType",
      "name": "physical-quantity",
      "base": "semantic",
      "description": "A named physical quantity with a value and unit produced by a measurement or observation \u2014 the shape plasma-physics's fundamental plasma-parameter quantities and cosmology's observational-cosmology and background-radiation parameters both independently converged on",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/measured"
      ],
      "subtype_of": [
        "mif:entityType/observation"
      ],
      "schema": {
        "required": [
          "parameter_name",
          "value",
          "variable"
        ],
        "properties": {
          "parameter_name": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "variable": {
            "type": "string",
            "description": "Inherited from research.ontology.yaml's observation: the measured variable name (same value as parameter_name)"
          },
          "unit": {
            "type": "string"
          }
        }
      }
    }
  ],
  "discovery": {
    "enabled": false,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(PACS code|classification scheme|physics classification)\\b",
        "suggest_entity": "mif:entityType/classification-scheme-entry",
        "suggest_namespace": "_semantic/physical-science"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(physical quantity|named quantity|measured parameter)\\b",
        "suggest_entity": "mif:entityType/physical-quantity",
        "suggest_namespace": "_semantic/physical-science"
      }
    ]
  }
}