{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "aliases": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },
    "exemplars": {
      "@id": "skos:example",
      "@container": "@set"
    },
    "negative_examples": {
      "@id": "https://mif-spec.dev/ns/ontology#negativeExample",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/mif-generic",
  "@type": "mif:Ontology",
  "identifier": "mif-generic",
  "version": "1.1.0",
  "description": "Basic generic ontology (MIF built-in entity types); always enabled for all topics.",
  "entity_types": [
    {
      "@id": "mif:entityType/concept",
      "@type": "mif:EntityType",
      "name": "concept",
      "base": "semantic",
      "description": "An abstract idea, theme, method, or topic.",
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Concept name"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/person",
      "@type": "mif:EntityType",
      "name": "person",
      "base": "semantic",
      "description": "An individual human actor.",
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Person name"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/organization",
      "@type": "mif:EntityType",
      "name": "organization",
      "base": "semantic",
      "description": "A company, institution, agency, or group.",
      "negative_examples": [
        "Global digital platforms are being designated as gatekeepers under new EU regulations, establishing a new class of regulated tech entities subject to stricter competition and transparency rules."
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Organization name"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/technology",
      "@type": "mif:EntityType",
      "name": "technology",
      "base": "semantic",
      "description": "A tool, system, framework, standard, or product.",
      "negative_examples": [
        "Pair programming is an engineering practice where two developers share one workstation and actively collaborate on the same code, with one driving and one navigating, improving code quality and knowledge sharing.",
        "The idea of a 'single pane of glass', one unified interface surfacing every signal (metrics, logs, traces, RUM, infrastructure state) an engineer needs to understand system health without pivoting between separate tools during an incident, is a widely invoked but frequently contested aspiration in observability. Practitioners who have operated genuinely large or heterogeneous environments argue that a true single pane spanning every team's tool choices is rarely achievable at organizational scale, given multiple cloud providers, acquired companies' legacy stacks, and diverging vendor selections; a smaller number of well-integrated views is the more realistic, commonly achieved outcome.",
        "The OpenTelemetry project's direction is set by a Governance Committee, with a separate Technical Committee and per-signal Special Interest Groups (traces, metrics, logs, profiles) handling specification design under CNCF's neutral-foundation model rather than any single vendor's roadmap. This governance structure is frequently credited with letting OpenTelemetry become a genuinely cross-vendor standard, succeeding where earlier vendor-specific or single-company-led tracing standards, OpenTracing and OpenCensus, which it absorbed and superseded in 2019, failed to reach the same universal adoption.",
        "In this envisioned future state, banking services would be embedded directly into non-bank platforms through open APIs, with consumers interacting with financial products via third-party interfaces rather than a bank's own channels. The US CFPB's 2024 Personal Financial Data Rights rule is cited as an early regulatory step toward this state, though it remains an emerging niche today rather than the dominant model. Broader open-finance mandates extending beyond payment accounts are identified as the key remaining trigger for this embedded model to become widespread.",
        "The EU Chips Act lays out a sequenced buildout of semiconductor fabrication and research capacity, backed by a EUR 43 billion combined public-and-private investment framework adopted in 2023, working toward a target of doubling the EU's share of the global semiconductor market to 20% by 2030. Fab construction permitting and financing, along with skilled semiconductor workforce availability, are flagged as the key dependencies standing between the plan and that end state, in support of the broader EU digital-sovereignty vision.",
        "As AI coding assistants increasingly automate routine implementation work, the relative value placed on junior-developer skill sets is shifting away from raw code production and toward code review, system design, and verifying AI-generated output. This is treated as an early-order implication still being debated among engineering-hiring leaders across the software industry, with genuine disagreement over how quickly and completely such a shift in required skills will actually take hold.",
        "Adoption of AI pair-programming tooling has scaled rapidly across the industry: GitHub reported Copilot usage crossing one million paid users and adoption by a majority of Fortune 500 companies within roughly two years of general availability, while internal engineering surveys at multiple large organizations report meaningful reported productivity gains on routine coding tasks. Competing offerings from Amazon, Google, and several startups have since entered the market, though the shift is still considered to be in an emerging maturity phase given ongoing debate over measured productivity impact at scale.",
        "Enterprise IT decision-makers (CIOs, VP Infrastructure) rely on technology platforms like Gartner research, proof-of-concept labs, and security-scanning tools to evaluate vendor claims before committing budget.",
        "Industrial IoT represents a market segment where manufacturing plants deploy wireless sensor networks, predictive-maintenance platforms, and AI-driven analytics to optimize production."
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Technology name"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/file",
      "@type": "mif:EntityType",
      "name": "file",
      "base": "semantic",
      "description": "A document, dataset, or artifact.",
      "negative_examples": [
        "A specific artifact type or data serialization format chosen for the system (e.g., 'we selected MongoDB over PostgreSQL'), representing the decision's concrete output.",
        "A concrete artifact of a single type with a specific identity (e.g., 'the parquet dataset snapshot from 2026-07-05 in S3 at path /datalake/v1/events/').",
        "Tempo is a distributed tracing backend service that indexes only trace IDs, keeping the full trace payload in low-cost object storage rather than a dedicated trace database. This trades away arbitrary tag-based search, answered instead by correlating trace IDs surfaced from metrics or logs, for much lower storage overhead at high trace volume. Its TraceQL query layer, added later, partially closes that search-capability gap by letting engineers filter traces on span attributes without needing a full secondary index over the stored data.",
        "Event sourcing is a design pattern where all state changes are recorded as an immutable sequence of events, allowing a system to reconstruct its state at any point in time by replaying events.",
        "Brendan Gregg is known for developing the USE method (Utilization, Saturation, Errors), a systematic way of diagnosing performance problems in any resource such as CPU, memory, disk, or network, and, separately, for extensive writing and conference material popularizing eBPF-based performance analysis and continuous profiling while at Netflix and later Intel. His flame graph visualization technique for rendering profiled stack-trace samples has become the de facto standard format most continuous-profiling tooling, including OpenTelemetry's newer Profiles signal, uses to present that data.",
        "Regulatory agencies are subjecting data-intensive industries to heightened scrutiny, with expanded enforcement budgets and new compliance frameworks affecting operational costs.",
        "K-12 learning-management systems offer integrated curriculum files, lesson-plan templates, and assessment resources that schools can customize and deploy across multiple classrooms."
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "File name or path"
          }
        }
      }
    }
  ],
  "relationships": {}
}